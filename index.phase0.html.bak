<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="可搬家的本機資料夾型內容管理系統初始化專案"
    />
    <title><%= siteName %></title>
  </head>
  <body class="lab-site lab-site--github">
    <header class="lab-header" data-sticky-header>
      <div class="lab-container lab-header__inner">
        <a class="lab-header__brand" href="/">Portable Blog System</a>
        <nav class="lab-nav" aria-label="主選單">
          <a href="#latest">最新文章</a>
          <a href="#categories">分類</a>
          <a href="#design-system">Design System</a>
        </nav>
        <button
          class="lab-header__menu-button"
          type="button"
          data-drawer-open
          aria-label="開啟選單"
        >
          ☰
        </button>
      </div>
    </header>

    <div class="lab-mobile-drawer" data-mobile-drawer aria-hidden="true">
      <button
        class="lab-mobile-drawer__close"
        type="button"
        data-drawer-close
        aria-label="關閉選單"
      >
        ×
      </button>
      <a href="#latest">最新文章</a>
      <a href="#categories">分類</a>
      <a href="#design-system">Design System</a>
    </div>
    <div class="lab-overlay" data-drawer-overlay hidden></div>

    <main>
      <section class="lab-hero">
        <div class="lab-container">
          <p class="lab-eyebrow">Phase 0 初始化骨架</p>
          <h1>可搬家的本機資料夾型內容管理系統</h1>
          <p>
            使用 Markdown + JSON 管理內容，以 Vite + EJS + SCSS 建立 GitHub
            Pages 與 Blogger 匯出流程。
          </p>
          <div class="lab-button-group">
            <a
              class="lab-button lab-button--primary"
              href="./docs/requirements.md"
              >查看需求文件</a
            >
            <a class="lab-button lab-button--outline" href="./CLAUDE.md"
              >查看 Claude 規範</a
            >
          </div>
        </div>
      </section>

      <section id="latest" class="lab-section">
        <div class="lab-container">
          <h2>最新文章卡片範例</h2>
          <div class="lab-card-grid">
            <article class="lab-post-card">
              <p class="lab-post-card__category">tech-note</p>
              <h3 class="lab-post-card__title">
                GitHub Pages 免費空間限制與部落格規劃
              </h3>
              <p class="lab-post-card__description">
                這是初始化用的 Markdown 範例文章，後續 Phase 1 會改為自動讀取
                content。
              </p>
              <a
                class="lab-post-card__link"
                href="./content/github/posts/20260504-github-pages-blog-planning.md"
                >閱讀 Markdown</a
              >
            </article>
            <article class="lab-post-card lab-post-card--featured">
              <p class="lab-post-card__category">book-review</p>
              <h3 class="lab-post-card__title">書評文章範本</h3>
              <p class="lab-post-card__description">
                用於 Blogger full 文章與聯盟行銷連結的 frontmatter 範本。
              </p>
              <!-- <a class="lab-post-card__link" href="./content/templates/blogger-book-review-template.md">查看範本</a> -->
              <a
                href="#"
                onclick="
                  alert(
                    'Phase 0 階段請先在 VS Code 中查看 content/templates/blogger-book-review-template.md',
                  );
                  return false;
                "
              >
                查看範本
              </a>
            </article>
          </div>
        </div>
      </section>

      <section id="categories" class="lab-section lab-section--muted">
        <div class="lab-container">
          <h2>分類入口</h2>
          <div class="lab-tag-list">
            <span class="lab-tag">技術筆記</span>
            <span class="lab-tag">書評</span>
            <span class="lab-tag">教具下載</span>
            <span class="lab-tag">生活文章</span>
          </div>
        </div>
      </section>

      <section id="design-system" class="lab-section">
        <div class="lab-container">
          <h2>Design System 起點</h2>
          <p>
            SCSS tokens、themes、buttons、cards、article components
            已建立占位檔，後續可由 Claude Code 分階段擴充。
          </p>
        </div>
      </section>
    </main>

    <footer class="lab-footer">
      <div class="lab-container">
        © 2026 Portable Blog System. Built for GitHub Pages + Blogger export.
      </div>
    </footer>

    <button
      class="lab-back-to-top"
      type="button"
      aria-label="回到頁面上方"
      data-back-to-top
    >
      ↑
    </button>
    <script type="module" src="/src/js/main.js"></script>
  </body>
</html>
