{
  "name": "portable-blog-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node src/scripts/build-github.js --mode=dev",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node src/scripts/build-github.js --mode=build",
    "build": "vite build",
    "postbuild": "npm run build:sitemap",
    "preview": "vite preview",
    "build:data": "node src/scripts/build-github.js",
    "build:github": "node src/scripts/build-github.js",
    "build:blogger": "node src/scripts/build-blogger.js",
    "build:promotion": "node src/scripts/build-promotion.js",
    "build:sitemap": "node src/scripts/build-sitemap.js",
    "build:blogger-theme": "node src/scripts/build-blogger-theme-css.js",
    "validate:content": "node src/scripts/validate-content.js",
    "validate:content:overlay": "node src/scripts/validate-content.js",
    "new:post": "node src/scripts/new-post.js",
    "backfill:url": "node src/scripts/backfill-published-url.js",
    "report:build": "node src/scripts/export-build-report.js",
    "report:drafts": "node src/scripts/report-draft-posts.js",
    "report:missing-tags": "node src/scripts/report-missing-tags.js",
    "report:urls": "node src/scripts/report-published-urls.js",
    "report:series": "node src/scripts/report-series.js",
    "report:book": "node src/scripts/report-book.js",
    "check:links": "node src/scripts/check-broken-links.js",
    "check:images": "node src/scripts/check-image-links.js",
    "smoke:reverse-utm": "node src/scripts/smoke-reverse-utm.js",
    "check:adsense-resolver": "node src/scripts/check-adsense-resolver.js",
    "safe-write:test": "node src/scripts/safe-write-test.js",
    "admin:write": "node src/scripts/admin-write-cli.js"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "latest",
    "ejs": "latest",
    "fast-glob": "latest",
    "gray-matter": "latest",
    "markdown-it": "latest",
    "sass": "latest",
    "vite": "latest",
    "vite-plugin-ejs": "latest"
  },
  "devDependencies": {}
}
