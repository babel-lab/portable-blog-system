<aside id="lab-drawer" class="lab-mobile-drawer" data-mobile-drawer
       role="dialog" aria-modal="true" aria-hidden="true" aria-label="行動選單">
  <button type="button" class="lab-mobile-drawer__close" data-drawer-close aria-label="關閉選單">×</button>
  <% if (navigation && navigation.length > 0) { %>
  <nav class="lab-mobile-drawer__nav" aria-label="行動選單導覽">
    <% navigation.forEach(function (item) { %>
    <a class="lab-mobile-drawer__link" href="<%= item.href %>"><%= item.label %></a>
    <% }); %>
  </nav>
  <% } %>
</aside>
<div class="lab-overlay" data-drawer-overlay hidden></div>
