<%# Phase 8-d-3c-2：低風險欄位改讀 normalized；保留 legacy fallback %>
<%# 模板實際使用之欄位中，僅 title / cover / coverAlt 屬本批低風險清單；contentKind / slug / description / excerpt 不在模板中，不新增 %>
<%# 不改 canonicalUrl / jsonLd / category / titleEn / date / updated / author / blocks / bodyHtml / ads partials %>
<%
const view = normalized || {};
const display = view.display || {};
const detailTitle = display.title || post.title;
const detailCover = display.cover || post.cover;
const detailCoverAlt = display.coverAlt || post.coverAlt || detailTitle;
// Phase 20260611-night-2（N8 anchor wiring）：六區塊 AdSense per-anchor resolved blocks（build 端 deriveRenderedAdsenseBlocks 注入）。
//   - 缺漏時退回空物件；ads.enabled=false（current production）→ 永遠 {} → 全 anchor zero-byte。
const _adsAnchors = (typeof adsenseBlocksRendered !== 'undefined' && adsenseBlocksRendered) ? adsenseBlocksRendered : {};
// Phase 20260626-github-gated-download-direct-file-guard-source-a：
//   防誤直出 guard（per docs/20260626-funnel-renderer-bridge-source-preflight-record-docs-only-a.md §8 P1 / §9 Optional guard）。
//   gated download 頁（pageType: gated_download）即使資料誤填 download.fileUrl，
//   也不得進入 legacy direct download box（line 115）而直出 <a download href> 繞過 gate。
//   - 純判斷，不新增 gated UI / placeholder UI；不消費 gatedDownload / downloadFunnel body。
//   - 非 gated 頁（pageType 缺省 / 其他值）行為 byte-identical：guard 為 false，既有 download box 不變。
const isGatedDownloadPage = !!(post && post.pageType === 'gated_download');
%>
<article class="lab-article">
  <header class="lab-article__header lab-container">
    <p class="lab-article__category"><%= post.category %></p>
    <h1 class="lab-article__title"><%= detailTitle %></h1>
    <% if (post.titleEn) { %>
    <p class="lab-article__title-en"><%= post.titleEn %></p>
    <% } %>
    <p class="lab-article__meta">
      <time datetime="<%= post.date %>"><%= post.date %></time>
      <% if (post.updated && post.updated !== post.date) { %>
      ·
      <span>更新於 <time datetime="<%= post.updated %>"><%= post.updated %></time></span>
      <% } %>
      <%# Shared author byline contract（2026-07-12）：post.byline?.showAuthor === false 才隱藏；omitted / true / 其他值一律顯示（backward-compatible default） -%>
      <% if (post.author && !(post.byline && post.byline.showAuthor === false)) { %>
      ·
      <span><%= post.author %></span>
      <% } %>
    </p>
  </header>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['afterHeader'], ads }) -%>

  <% if (detailCover) { %>
  <div class="lab-container">
    <div class="lab-article__cover">
      <img class="lab-article__cover-img"
           src="<%= detailCover %>"
           alt="<%= detailCoverAlt || '' %>"
           decoding="async"
           width="1200" height="630">
    </div>
  </div>
  <% } %>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['afterCover'], ads }) -%>

  <%# Phase 9-h-e-b：Book Photo 區塊（mirror Blogger 端 post-full.ejs 之 book photo pattern） -%>
  <%# 4 條 AND guard：post.contentKind 為 book-review / post.book 存在 / post.book.showBookPhoto 為 truthy / post.book.coverImage 有值 -%>
  <%# 對非 book-review 或 4 條 guard 不通過之既有 ready post，本區塊完全不渲染 -%>
  <%# 沿用 lab-book-photo BEM；SCSS 已就位（_book-photo.scss + main.scss line 28 import 已就位） -%>
  <%# img alt 三層 fallback：post.book.coverAlt → post.book.title → 空字串（mirror Blogger） -%>
  <%# figcaption 條件渲染：僅當 post.book.title 有值時輸出；publisher 為 nested optional append -%>
  <%# 本批不接 normalize-post-output；直接讀 post.contentKind（mirror 9-h-b-b / 9-h-c-b / 9-h-d-b 既有 pattern） -%>
  <%# trim-newline pattern：對非 book-review 之 ready post，index.html 結構性 byte-identical-modulo-builtAt -%>
  <%# 本批 EJS comment 嚴格無 EJS delimiter 字符（mirror 9-g-d-c-fix / 9-g-f-b / 9-h-b-b / 9-h-c-b / 9-h-d-b 既有預防經驗） -%>
  <% if (post.contentKind === 'book-review' && post.book && post.book.showBookPhoto && post.book.coverImage) { %>
  <div class="lab-container">
    <figure class="lab-book-photo">
      <img class="lab-book-photo__image" src="<%= post.book.coverImage %>" alt="<%= post.book.coverAlt || post.book.title || '' %>">
      <% if (post.book.title) { %>
      <figcaption class="lab-book-photo__caption">《<%= post.book.title %>》<% if (post.book.publisher) { %> — <%= post.book.publisher %><% } %></figcaption>
      <% } %>
    </figure>
  </div>
  <% } -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['afterBookPhoto'], ads }) -%>

  <% if (typeof ads !== 'undefined' && ads && ads.enabled === true && post.blocks && post.blocks.adsenseTop) { %>
  <div class="lab-container">
    <%- await include('../ads/adsense-post-top', { ads }) %>
  </div>
  <% } %>

  <%# Phase 9-h-b-b：聯盟販售連結 Box 前置（mirror Blogger 端 post-full.ejs 之 affiliate top） -%>
  <%# 5 條 AND guard：affiliate 存在 / enabled 為 true / links 非空 array / position 存在 / position.top 為 true -%>
  <%# 對無 affiliate 或 5 條 guard 不通過之既有 ready post，本區塊完全不渲染 -%>
  <%# 沿用 lab-affiliate-box BEM；SCSS 已於 Phase 2-2-p 落地（_affiliate-box.scss + main.scss import 已就位） -%>
  <%# rel 固定 sponsored nofollow noopener noreferrer；target 固定 _blank；無 author override -%>
  <%# trim-newline pattern：對無 affiliate 之 ready post，index.html 結構性 byte-identical-modulo-builtAt -%>
  <%# 本批 EJS comment 嚴格無 EJS delimiter 字符（mirror 9-g-d-c-fix / 9-g-f-b 既有預防經驗） -%>
  <%# Phase 20260610-am-6：links 來源改讀 build 端 resolved affiliateLinksRendered（ref→targetUrl / omit 已處理；url 保證非空，避免 href="undefined"）；enabled / position guard 仍讀 post.affiliate -%>
  <% if (post.affiliate && post.affiliate.enabled && Array.isArray(affiliateLinksRendered) && affiliateLinksRendered.length > 0 && post.affiliate.position && post.affiliate.position.top) { %>
  <div class="lab-container">
    <aside class="lab-affiliate-box">
      <h3 class="lab-affiliate-box__title">立即購買</h3>
      <% if (post.affiliate.disclosure) { %>
      <p class="lab-affiliate-box__disclosure"><%= post.affiliate.disclosure %></p>
      <% } %>
      <ul class="lab-affiliate-box__links">
        <% affiliateLinksRendered.forEach(function(link) { %>
        <%# Phase 20260522-ga4-inline-attrs-after-revert-a: inline GA4 click tracking attrs on top CTA；移除 helper include 避開 async EJS issue；href/rel/target/class 不動 -%>
        <li><a class="lab-affiliate-box__link" href="<%= link.url %>" rel="sponsored nofollow noopener noreferrer" target="_blank" data-ga4-event="click_affiliate_cta" data-ga4-param-post_slug="<%= post.slug %>" data-ga4-param-link_label="<%= link.label %>" data-ga4-param-link_type="affiliate" data-ga4-param-link_url="<%= link.url %>" data-ga4-param-outbound="true" data-ga4-param-provider="<%= link.network || '' %>" data-ga4-param-placement="article_top"><%= link.label %><% if (link.network) { %> <span class="lab-affiliate-box__network"><%= link.network %></span><% } %></a></li>
        <% }); %>
      </ul>
    </aside>
  </div>
  <% } -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['afterAffiliateTop'], ads }) -%>

  <div class="lab-article__body lab-container">
    <%- bodyHtml %>
  </div>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['beforeDownloadBox'], ads }) -%>

  <%# Phase 9-h-c-b：教具下載 Box（mirror Blogger 端 post-full.ejs 之 download box） -%>
  <%# 3 條 AND guard：download 存在 / enabled 為 true / fileUrl 有值 -%>
  <%# 對無 download 或 3 條 guard 不通過之既有 ready post，本區塊完全不渲染 -%>
  <%# 沿用 lab-download-box BEM；SCSS 已於 Phase 2-2-o 落地（_download-box.scss + main.scss import 已就位） -%>
  <%# a 標籤使用 HTML5 download 屬性；不加 target；不加 rel（mirror Blogger pattern；download 為自家教具非聯盟） -%>
  <%# title / description / fileType / licenseNote 皆選填；有值才輸出對應元素 -%>
  <%# 本批不加 per-item filter / URL 驗證 / validate rule / GA4 event；mirror Blogger 既有 pattern -%>
  <%# trim-newline pattern：對無 download 之 ready post，index.html 結構性 byte-identical-modulo-builtAt -%>
  <%# 本批 EJS comment 嚴格無 EJS delimiter 字符（mirror 9-g-d-c-fix / 9-g-f-b / 9-h-b-b 既有預防經驗） -%>
  <%# Phase 20260626-github-gated-download-direct-file-guard-source-a：guard 前置 isGatedDownloadPage，gated 頁不直出 fileUrl direct download link -%>
  <% if (!isGatedDownloadPage && post.download && post.download.enabled && post.download.fileUrl) { %>
  <div class="lab-container">
    <aside class="lab-download-box">
      <% if (post.download.title) { %>
      <h3 class="lab-download-box__title"><%= post.download.title %></h3>
      <% } %>
      <% if (post.download.description) { %>
      <p class="lab-download-box__description"><%= post.download.description %></p>
      <% } %>
      <a class="lab-download-box__cta" href="<%= post.download.fileUrl %>" download>
        <% if (post.download.fileType) { %><span class="lab-download-box__filetype"><%= post.download.fileType %></span><% } %>下載檔案
      </a>
      <% if (post.download.licenseNote) { %>
      <p class="lab-download-box__license"><%= post.download.licenseNote %></p>
      <% } %>
    </aside>
  </div>
  <% } -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['afterDownloadBox'], ads }) -%>

  <%# Phase 20260603-pm-2：下載落地頁 minimal guarded branch（Option D；per docs/20260603-download-landing-page-content-model-decision.md §5 / §7 / §11） -%>
  <%# Phase 20260603-pm-7：改用 build 端 registry-resolved derived object downloadLandingRendered（Option A）；registry empty 時 graceful fallback 到 placeholder -%>
  <%# 主 guard（§7.2 G-c）：download 存在 / enabled 為 true / landingPage 為 true；explicit boolean 避免與一般 download box 誤判 -%>
  <%# 與既有 lab-download-box（fileUrl guard，line 106）正交：本分支 append-only，不改既有 download box 之 fileUrl 行為 -%>
  <%# 紅線：registry empty / 未 resolve 時不輸出 Google Form URL / Google Drive URL；不收 respondent data；不做 network reachability；form / asset 僅顯示 title / label / fileType -%>
  <%# title fallback：downloadLandingRendered.title → download.title → detailTitle（display.title 或 post.title）；摘要 fallback：derived description → download.description → post.description → post.searchDescription -%>
  <%# downloadLandingRendered 不存在或 null 時 graceful fallback 到 placeholder（不 crash） -%>
  <%# 不新增 SCSS / JS：沿用 lab-download-box BEM；新增 element class 無對應樣式時僅為語意結構 -%>
  <%# trim-newline pattern：對無 landingPage 之既有 ready post，index.html 結構性 byte-identical-modulo-builtAt -%>
  <%# 本批 EJS comment 嚴格無 EJS delimiter 字符（mirror 既有 download box / affiliate / hashtag 預防經驗） -%>
  <% if (post.download && post.download.enabled === true && post.download.landingPage === true) { %>
  <% const dl = (typeof downloadLandingRendered !== 'undefined' && downloadLandingRendered) ? downloadLandingRendered : null; %>
  <div class="lab-container">
    <section class="lab-download-box lab-download-box--landing">
      <h2 class="lab-download-box__title"><%= (dl && dl.title) || post.download.title || detailTitle %></h2>
      <% const landingDesc = (dl && dl.description) || post.download.description || post.description || post.searchDescription; %>
      <% if (landingDesc) { %>
      <p class="lab-download-box__description"><%= landingDesc %></p>
      <% } %>
      <div class="lab-download-box__form-placeholder">
        <% if (dl && dl.form && dl.form.found && dl.form.title) { %>
        <p>表單：<%= dl.form.title %></p>
        <% } else { %>
        <p>表單暫不可用 / 尚未設定表單。</p>
        <% } %>
      </div>
      <div class="lab-download-box__asset-placeholder">
        <% const resolvedAssets = (dl && Array.isArray(dl.assets)) ? dl.assets.filter(function (a) { return a && a.found; }) : []; %>
        <% if (resolvedAssets.length > 0) { %>
        <ul class="lab-download-box__asset-list">
          <% resolvedAssets.forEach(function (a) { %>
          <li><%= a.title %><% if (a.fileType) { %>（<%= a.fileType %>）<% } %></li>
          <% }); %>
        </ul>
        <% } else { %>
        <p>下載資產暫不可用 / 尚未設定下載資產。</p>
        <% } %>
      </div>
      <p class="lab-download-box__note">填表資料由外部表單服務處理，不儲存在本站靜態檔案中。</p>
    </section>
  </div>
  <% } -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['beforeAffiliateBottom'], ads }) -%>

  <%# Phase 9-h-b-b：聯盟販售連結 Box 後置（mirror Blogger 端 post-full.ejs 之 affiliate bottom） -%>
  <%# 5 條 AND guard：affiliate 存在 / enabled 為 true / links 非空 array / position 存在 / position.bottom 為 true -%>
  <%# 對無 affiliate 或 5 條 guard 不通過之既有 ready post，本區塊完全不渲染 -%>
  <%# 同 affiliate top 之 markup pattern；沿用 lab-affiliate-box BEM；不接 normalize-post-output -%>
  <%# Phase 20260610-am-6：同 top，links 來源改讀 resolved affiliateLinksRendered -%>
  <% if (post.affiliate && post.affiliate.enabled && Array.isArray(affiliateLinksRendered) && affiliateLinksRendered.length > 0 && post.affiliate.position && post.affiliate.position.bottom) { %>
  <div class="lab-container">
    <aside class="lab-affiliate-box">
      <h3 class="lab-affiliate-box__title">立即購買</h3>
      <% if (post.affiliate.disclosure) { %>
      <p class="lab-affiliate-box__disclosure"><%= post.affiliate.disclosure %></p>
      <% } %>
      <ul class="lab-affiliate-box__links">
        <% affiliateLinksRendered.forEach(function(link) { %>
        <%# Phase 20260522-ga4-inline-attrs-after-revert-a: inline GA4 click tracking attrs on bottom CTA；mirror top；唯一 diff: placement；移除 helper include 避開 async EJS issue -%>
        <li><a class="lab-affiliate-box__link" href="<%= link.url %>" rel="sponsored nofollow noopener noreferrer" target="_blank" data-ga4-event="click_affiliate_cta" data-ga4-param-post_slug="<%= post.slug %>" data-ga4-param-link_label="<%= link.label %>" data-ga4-param-link_type="affiliate" data-ga4-param-link_url="<%= link.url %>" data-ga4-param-outbound="true" data-ga4-param-provider="<%= link.network || '' %>" data-ga4-param-placement="article_bottom"><%= link.label %><% if (link.network) { %> <span class="lab-affiliate-box__network"><%= link.network %></span><% } %></a></li>
        <% }); %>
      </ul>
    </aside>
  </div>
  <% } -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['afterAffiliateBottom'], ads }) -%>

  <%# Phase 9-g-f-b：相關連結（作者手動指定；mirror Blogger 9-g-d-b pattern） -%>
  <%# Phase related-links-ga4-audit：改讀 relatedLinksRendered / otherLinksRendered（含 Blogger cross-link UTM + target/rel） -%>
  <%# renderable pre-filter：plain object 且 url 非空 且 title 非空 才渲染；其餘 skip -%>
  <%# Blogger cross-link（item.target/item.rel 由 build-github 預處理填入）採其值；其餘 kind=internal 不加 target/rel；非 internal 走 external default _blank + nofollow noopener -%>
  <%# 本批忽略 item.order；author item.target / item.rel override 仍經 mergeRel 合併 -%>
  <%# trim-newline pattern：對無 relatedLinks / otherLinks 之 ready post，index.html 結構性 byte-identical-modulo-builtAt -%>
  <%# 本批 EJS comment 內嚴格不出現 EJS delimiter 文字（避免 9-g-d-c / 9-g-e-b 之既有 bug 模式） -%>
  <%
    const renderableRelated = (Array.isArray(relatedLinksRendered) ? relatedLinksRendered : []).filter(function(item) {
      return item && typeof item === 'object' && !Array.isArray(item)
        && typeof item.url === 'string' && item.url.trim() !== ''
        && typeof item.title === 'string' && item.title.trim() !== '';
    });
  -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['beforeRelatedLinks'], ads }) -%>
  <% if (renderableRelated.length > 0) { %>
  <div class="lab-container">
    <aside class="lab-related-links">
      <h2 class="lab-related-links__title">相關連結</h2>
      <ul class="lab-related-links__list">
        <% renderableRelated.forEach(function(item) {
          const isInternal = item.kind === 'internal';
          // Phase 20260527-am-2 step-4：sourceKey → registry.displayLabel；fallback 至 item.platform
          const platform = (typeof item.resolvedLabel === 'string' && item.resolvedLabel.trim() !== '')
            ? item.resolvedLabel.trim()
            : ((typeof item.platform === 'string' && item.platform.trim() !== '') ? item.platform.trim() : '');
          const hasDesc = typeof item.description === 'string' && item.description.trim() !== '';
          const finalTarget = (typeof item.target === 'string' && item.target !== '') ? item.target : (isInternal ? null : '_blank');
          const finalRel = (typeof item.rel === 'string' && item.rel !== '') ? item.rel : (isInternal ? null : 'nofollow noopener');
          const isCrossSite = typeof item.target === 'string' && item.target !== '';
          const linkType = isCrossSite ? 'cross_site' : (isInternal ? 'internal' : 'external');
          const outbound = (isInternal || isCrossSite) ? 'false' : 'true';
        %>
        <%# Phase 20260522-ga4-inline-attrs-after-revert-a: inline GA4 click tracking attrs on relatedLinks anchor；移除 helper include 避開 async EJS issue；href/target/rel/class 不動 -%>
        <li class="lab-related-links__item lab-related-links__item--<%= isInternal ? 'internal' : 'external' %>">
          <a class="lab-related-links__link" href="<%= item.url %>"<% if (finalTarget) { %> target="<%= finalTarget %>"<% } %><% if (finalRel) { %> rel="<%= finalRel %>"<% } %> data-ga4-event="click_related_link" data-ga4-param-post_slug="<%= post.slug %>" data-ga4-param-link_label="<%= item.title %>" data-ga4-param-link_type="<%= linkType %>" data-ga4-param-link_url="<%= item.url %>" data-ga4-param-outbound="<%= outbound %>" data-ga4-param-placement="related_links"<% if (typeof item.sourceKey === 'string' && item.sourceKey.trim() !== '') { %> data-ga4-param-link_source_key="<%= item.sourceKey.trim() %>"<% } %>>
            <% if (platform) { %><span class="lab-related-links__platform">[<%= platform %>]</span> <% } %><span class="lab-related-links__title-text"><%= item.title %></span>
          </a>
          <% if (hasDesc) { %><p class="lab-related-links__description"><%= item.description %></p><% } %>
        </li>
        <% }); %>
      </ul>
    </aside>
  </div>
  <% } -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['afterRelatedLinks'], ads }) -%>

  <%# Phase 9-g-f-b：其他連結（同 lab-related-links 規則，class prefix 改 lab-other-links） -%>
  <%# Phase related-links-ga4-audit：讀 otherLinksRendered；utm_content=other_links -%>
  <%
    const renderableOther = (Array.isArray(otherLinksRendered) ? otherLinksRendered : []).filter(function(item) {
      return item && typeof item === 'object' && !Array.isArray(item)
        && typeof item.url === 'string' && item.url.trim() !== ''
        && typeof item.title === 'string' && item.title.trim() !== '';
    });
  -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['beforeOtherLinks'], ads }) -%>
  <% if (renderableOther.length > 0) { %>
  <div class="lab-container">
    <aside class="lab-other-links">
      <h2 class="lab-other-links__title">其他連結</h2>
      <ul class="lab-other-links__list">
        <% renderableOther.forEach(function(item) {
          const isInternal = item.kind === 'internal';
          // Phase 20260527-am-2 step-4：sourceKey → registry.displayLabel；fallback 至 item.platform
          const platform = (typeof item.resolvedLabel === 'string' && item.resolvedLabel.trim() !== '')
            ? item.resolvedLabel.trim()
            : ((typeof item.platform === 'string' && item.platform.trim() !== '') ? item.platform.trim() : '');
          const hasDesc = typeof item.description === 'string' && item.description.trim() !== '';
          const finalTarget = (typeof item.target === 'string' && item.target !== '') ? item.target : (isInternal ? null : '_blank');
          const finalRel = (typeof item.rel === 'string' && item.rel !== '') ? item.rel : (isInternal ? null : 'nofollow noopener');
          const isCrossSite = typeof item.target === 'string' && item.target !== '';
          const linkType = isCrossSite ? 'cross_site' : (isInternal ? 'internal' : 'external');
          const outbound = (isInternal || isCrossSite) ? 'false' : 'true';
        %>
        <%# Phase 20260522-ga4-inline-attrs-after-revert-a: inline GA4 click tracking attrs on otherLinks anchor；mirror relatedLinks；唯一 diff: event 為 click_other_link；移除 helper include 避開 async EJS issue -%>
        <li class="lab-other-links__item lab-other-links__item--<%= isInternal ? 'internal' : 'external' %>">
          <a class="lab-other-links__link" href="<%= item.url %>"<% if (finalTarget) { %> target="<%= finalTarget %>"<% } %><% if (finalRel) { %> rel="<%= finalRel %>"<% } %> data-ga4-event="click_other_link" data-ga4-param-post_slug="<%= post.slug %>" data-ga4-param-link_label="<%= item.title %>" data-ga4-param-link_type="<%= linkType %>" data-ga4-param-link_url="<%= item.url %>" data-ga4-param-outbound="<%= outbound %>" data-ga4-param-placement="other_links"<% if (typeof item.sourceKey === 'string' && item.sourceKey.trim() !== '') { %> data-ga4-param-link_source_key="<%= item.sourceKey.trim() %>"<% } %>>
            <% if (platform) { %><span class="lab-other-links__platform">[<%= platform %>]</span> <% } %><span class="lab-other-links__title-text"><%= item.title %></span>
          </a>
          <% if (hasDesc) { %><p class="lab-other-links__description"><%= item.description %></p><% } %>
        </li>
        <% }); %>
      </ul>
    </aside>
  </div>
  <% } -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['afterOtherLinks'], ads }) -%>

  <%# Phase 9-h-d-b：Hashtag 區塊（mirror Blogger 端 post-full.ejs 之 hashtag pattern） -%>
  <%# 4 條 AND guard：post.blocks 存在 / post.blocks.hashtags 為 truthy / post.tags 是 array / post.tags.length 大於 0 -%>
  <%# 對無 tags 或 blocks.hashtags 不為 true 之既有 ready post，本區塊完全不渲染 -%>
  <%# 沿用 lab-hashtags / lab-hashtag BEM；SCSS 已於 Phase 2-2-g 落地（_hashtag.scss + main.scss line 23 import 已就位） -%>
  <%# hashtag 本批採 display-only span 設計（mirror Blogger）；不加 hashtag link / target / rel / GA4 event -%>
  <%# 本批不接 normalize-post-output；直接讀 post.tags（mirror Blogger 既有 pattern） -%>
  <%# trim-newline pattern：對無 hashtag 之 ready post，index.html 結構性 byte-identical-modulo-builtAt -%>
  <%# 本批 EJS comment 嚴格無 EJS delimiter 字符（mirror 9-g-d-c-fix / 9-g-f-b / 9-h-b-b / 9-h-c-b 既有預防經驗） -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['beforeHashtags'], ads }) -%>
  <% if (post.blocks && post.blocks.hashtags && Array.isArray(post.tags) && post.tags.length > 0) { %>
  <div class="lab-container">
    <ul class="lab-hashtags">
      <% post.tags.forEach(function(tag) { %>
      <li><span class="lab-hashtag">#<%= tag %></span></li>
      <% }); %>
    </ul>
  </div>
  <% } -%>
<%- await include('../ads/adsense-anchor', { blocks: _adsAnchors['afterHashtags'], ads }) -%>

  <% if (typeof ads !== 'undefined' && ads && ads.enabled === true && post.blocks && post.blocks.adsenseBottom) { %>
  <div class="lab-container">
    <%- await include('../ads/adsense-post-bottom', { ads }) %>
  </div>
  <% } %>
</article>
<%# Phase 20260615-am-2：文章底部導覽（上一篇 / 下一篇 / 回首頁）；獨立 partial，置於 </article> 之外，不在文章正文內。 -%>
<%- await include('../layout/article-bottom-nav', { post: post, prevPost: (typeof prevPost !== 'undefined' ? prevPost : null), nextPost: (typeof nextPost !== 'undefined' ? nextPost : null), basePath: basePath }) -%>
