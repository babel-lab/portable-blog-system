<%# Phase 8-d-3c-2：低風險欄位改讀 normalized；保留 legacy fallback %>
<%# 模板實際使用之欄位中，僅 title / cover / coverAlt 屬本批低風險清單；contentKind / slug / description / excerpt 不在模板中，不新增 %>
<%# 不改 canonicalUrl / jsonLd / category / titleEn / date / updated / author / blocks / bodyHtml / ads partials %>
<%
const view = normalized || {};
const display = view.display || {};
const detailTitle = display.title || post.title;
const detailCover = display.cover || post.cover;
const detailCoverAlt = display.coverAlt || post.coverAlt || detailTitle;
%>
<article class="lab-article">
  <header class="lab-article__header lab-container">
    <p class="lab-article__category"><%= post.category %></p>
    <h1 class="lab-article__title"><%= detailTitle %></h1>
    <% if (post.titleEn) { %>
    <p class="lab-article__title-en"><%= post.titleEn %></p>
    <% } %>
    <p class="lab-article__meta">
      <time datetime="<%= post.date %>"><%= post.date %></time>
      <% if (post.updated && post.updated !== post.date) { %>
      ·
      <span>更新於 <time datetime="<%= post.updated %>"><%= post.updated %></time></span>
      <% } %>
      <% if (post.author) { %>
      ·
      <span><%= post.author %></span>
      <% } %>
    </p>
  </header>

  <% if (detailCover) { %>
  <div class="lab-container">
    <div class="lab-article__cover">
      <img class="lab-article__cover-img"
           src="<%= detailCover %>"
           alt="<%= detailCoverAlt || '' %>"
           decoding="async"
           width="1200" height="630">
    </div>
  </div>
  <% } %>

  <% if (typeof ads !== 'undefined' && ads && ads.enabled === true && post.blocks && post.blocks.adsenseTop) { %>
  <div class="lab-container">
    <%- await include('../ads/adsense-post-top', { ads }) %>
  </div>
  <% } %>

  <%# Phase 9-h-b-b：聯盟販售連結 Box 前置（mirror Blogger 端 post-full.ejs 之 affiliate top） -%>
  <%# 5 條 AND guard：affiliate 存在 / enabled 為 true / links 非空 array / position 存在 / position.top 為 true -%>
  <%# 對無 affiliate 或 5 條 guard 不通過之既有 ready post，本區塊完全不渲染 -%>
  <%# 沿用 lab-affiliate-box BEM；SCSS 已於 Phase 2-2-p 落地（_affiliate-box.scss + main.scss import 已就位） -%>
  <%# rel 固定 sponsored nofollow noopener noreferrer；target 固定 _blank；無 author override -%>
  <%# trim-newline pattern：對無 affiliate 之 ready post，index.html 結構性 byte-identical-modulo-builtAt -%>
  <%# 本批 EJS comment 嚴格無 EJS delimiter 字符（mirror 9-g-d-c-fix / 9-g-f-b 既有預防經驗） -%>
  <% if (post.affiliate && post.affiliate.enabled && Array.isArray(post.affiliate.links) && post.affiliate.links.length > 0 && post.affiliate.position && post.affiliate.position.top) { %>
  <div class="lab-container">
    <aside class="lab-affiliate-box">
      <h3 class="lab-affiliate-box__title">立即購買</h3>
      <% if (post.affiliate.disclosure) { %>
      <p class="lab-affiliate-box__disclosure"><%= post.affiliate.disclosure %></p>
      <% } %>
      <ul class="lab-affiliate-box__links">
        <% post.affiliate.links.forEach(function(link) { %>
        <li><a class="lab-affiliate-box__link" href="<%= link.url %>" rel="sponsored nofollow noopener noreferrer" target="_blank"><%= link.label %><% if (link.network) { %> <span class="lab-affiliate-box__network"><%= link.network %></span><% } %></a></li>
        <% }); %>
      </ul>
    </aside>
  </div>
  <% } -%>

  <div class="lab-article__body lab-container">
    <%- bodyHtml %>
  </div>

  <%# Phase 9-h-b-b：聯盟販售連結 Box 後置（mirror Blogger 端 post-full.ejs 之 affiliate bottom） -%>
  <%# 5 條 AND guard：affiliate 存在 / enabled 為 true / links 非空 array / position 存在 / position.bottom 為 true -%>
  <%# 對無 affiliate 或 5 條 guard 不通過之既有 ready post，本區塊完全不渲染 -%>
  <%# 同 affiliate top 之 markup pattern；沿用 lab-affiliate-box BEM；不接 normalize-post-output -%>
  <% if (post.affiliate && post.affiliate.enabled && Array.isArray(post.affiliate.links) && post.affiliate.links.length > 0 && post.affiliate.position && post.affiliate.position.bottom) { %>
  <div class="lab-container">
    <aside class="lab-affiliate-box">
      <h3 class="lab-affiliate-box__title">立即購買</h3>
      <% if (post.affiliate.disclosure) { %>
      <p class="lab-affiliate-box__disclosure"><%= post.affiliate.disclosure %></p>
      <% } %>
      <ul class="lab-affiliate-box__links">
        <% post.affiliate.links.forEach(function(link) { %>
        <li><a class="lab-affiliate-box__link" href="<%= link.url %>" rel="sponsored nofollow noopener noreferrer" target="_blank"><%= link.label %><% if (link.network) { %> <span class="lab-affiliate-box__network"><%= link.network %></span><% } %></a></li>
        <% }); %>
      </ul>
    </aside>
  </div>
  <% } -%>

  <%# Phase 9-g-f-b：相關連結（作者手動指定；mirror Blogger 9-g-d-b pattern） -%>
  <%# renderable pre-filter：plain object 且 url 非空 且 title 非空 才渲染；其餘 skip -%>
  <%# kind 為 internal 時不加 target 與 rel；其他採 external default 開新分頁 + nofollow noopener -%>
  <%# 本批忽略 item.order；不支援 item.target / item.rel author override；不接 normalize-post-output -%>
  <%# trim-newline pattern：對無 relatedLinks / otherLinks 之 ready post，index.html 結構性 byte-identical-modulo-builtAt -%>
  <%# 本批 EJS comment 內嚴格不出現 EJS delimiter 文字（避免 9-g-d-c / 9-g-e-b 之既有 bug 模式） -%>
  <%
    const renderableRelated = (Array.isArray(post.relatedLinks) ? post.relatedLinks : []).filter(function(item) {
      return item && typeof item === 'object' && !Array.isArray(item)
        && typeof item.url === 'string' && item.url.trim() !== ''
        && typeof item.title === 'string' && item.title.trim() !== '';
    });
  -%>
  <% if (renderableRelated.length > 0) { %>
  <div class="lab-container">
    <aside class="lab-related-links">
      <h2 class="lab-related-links__title">相關連結</h2>
      <ul class="lab-related-links__list">
        <% renderableRelated.forEach(function(item) {
          const isInternal = item.kind === 'internal';
          const platform = (typeof item.platform === 'string' && item.platform.trim() !== '') ? item.platform.trim() : '';
          const hasDesc = typeof item.description === 'string' && item.description.trim() !== '';
        %>
        <li class="lab-related-links__item lab-related-links__item--<%= isInternal ? 'internal' : 'external' %>">
          <a class="lab-related-links__link" href="<%= item.url %>"<% if (!isInternal) { %> target="_blank" rel="nofollow noopener"<% } %>>
            <% if (platform) { %><span class="lab-related-links__platform">[<%= platform %>]</span> <% } %><span class="lab-related-links__title-text"><%= item.title %></span>
          </a>
          <% if (hasDesc) { %><p class="lab-related-links__description"><%= item.description %></p><% } %>
        </li>
        <% }); %>
      </ul>
    </aside>
  </div>
  <% } -%>

  <%# Phase 9-g-f-b：其他連結（同 lab-related-links 規則，class prefix 改 lab-other-links） -%>
  <%
    const renderableOther = (Array.isArray(post.otherLinks) ? post.otherLinks : []).filter(function(item) {
      return item && typeof item === 'object' && !Array.isArray(item)
        && typeof item.url === 'string' && item.url.trim() !== ''
        && typeof item.title === 'string' && item.title.trim() !== '';
    });
  -%>
  <% if (renderableOther.length > 0) { %>
  <div class="lab-container">
    <aside class="lab-other-links">
      <h2 class="lab-other-links__title">其他連結</h2>
      <ul class="lab-other-links__list">
        <% renderableOther.forEach(function(item) {
          const isInternal = item.kind === 'internal';
          const platform = (typeof item.platform === 'string' && item.platform.trim() !== '') ? item.platform.trim() : '';
          const hasDesc = typeof item.description === 'string' && item.description.trim() !== '';
        %>
        <li class="lab-other-links__item lab-other-links__item--<%= isInternal ? 'internal' : 'external' %>">
          <a class="lab-other-links__link" href="<%= item.url %>"<% if (!isInternal) { %> target="_blank" rel="nofollow noopener"<% } %>>
            <% if (platform) { %><span class="lab-other-links__platform">[<%= platform %>]</span> <% } %><span class="lab-other-links__title-text"><%= item.title %></span>
          </a>
          <% if (hasDesc) { %><p class="lab-other-links__description"><%= item.description %></p><% } %>
        </li>
        <% }); %>
      </ul>
    </aside>
  </div>
  <% } -%>

  <% if (typeof ads !== 'undefined' && ads && ads.enabled === true && post.blocks && post.blocks.adsenseBottom) { %>
  <div class="lab-container">
    <%- await include('../ads/adsense-post-bottom', { ads }) %>
  </div>
  <% } %>
</article>
