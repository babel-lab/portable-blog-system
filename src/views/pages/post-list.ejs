<section class="lab-section">
  <div class="lab-container">
    <h1>文章列表</h1>
    <% if (!posts || posts.length === 0) { %>
    <p>目前沒有可顯示的文章。</p>
    <% } else { %>
    <ul class="lab-post-list">
      <%# Phase 8-d-3c-4：迴圈內 per-item view-model；低風險欄位（title / cover / coverAlt / slug / description）優先讀 normalized；保留 legacy fallback %>
      <%# 模板實際使用之欄位中，contentKind / type / excerpt 未在模板，依指令不新增；不改 HTML 結構 / class name / category / titleEn / date 之既有讀法 %>
      <% posts.forEach(function (post) {
        const itemView = post.normalized || {};
        const itemDisplay = itemView.display || {};
        const itemIdentity = itemView.identity || {};
        const itemTitle = itemDisplay.title || post.title;
        const itemDescription = itemDisplay.description || post.description;
        const itemCover = itemDisplay.cover || post.cover;
        const itemCoverAlt = itemDisplay.coverAlt || post.coverAlt || itemTitle;
        const itemSlug = itemIdentity.slug || post.slug;
      %>
      <li class="lab-post-list__item">
        <article class="lab-post-card">
          <% if (itemCover) { %>
          <div class="lab-post-card__cover">
            <img class="lab-post-card__cover-img"
                 src="<%= itemCover %>"
                 alt="<%= itemCoverAlt || '' %>"
                 loading="lazy"
                 decoding="async"
                 width="1200" height="630">
          </div>
          <% } %>
          <p class="lab-post-card__category"><%= post.category %></p>
          <h2 class="lab-post-card__title">
            <a href="/posts/<%= itemSlug %>/"><%= itemTitle %></a>
          </h2>
          <% if (post.titleEn) { %>
          <p class="lab-post-card__title-en"><%= post.titleEn %></p>
          <% } %>
          <% if (itemDescription) { %>
          <p class="lab-post-card__description"><%= itemDescription %></p>
          <% } %>
          <p class="lab-post-card__meta">
            <time datetime="<%= post.date %>"><%= post.date %></time>
          </p>
        </article>
      </li>
      <% }); %>
    </ul>
    <% } %>
  </div>
</section>
