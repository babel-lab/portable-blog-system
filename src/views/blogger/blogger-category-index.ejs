<%# Phase 3-e-6：Blogger 分類索引（單一分類） %>
<div class="lab-blogger-components">

  <header>
    <h1>分類：<%= categoryName %>（<%= posts.length %> 篇）</h1>
    <p>建置時間 <%= builtAt %></p>
    <p><a href="blogger-home.html">← 返回首頁索引</a></p>
  </header>

  <ul class="lab-card-grid">
    <%# Phase 8-d-3c-8-a：迴圈內 per-item view-model；資料來源為 build-blogger.js indexPosts 投影（本批同步在投影層 additive 加入 normalized） %>
    <%# 沿用 8-d-3c-4～7 命名（itemView / itemDisplay / itemPublish），不臆造 normalized.urls 命名空間 %>
    <%# normalized 對應欄位之 fallback：title → display.title；description → display.description；bloggerPublishedUrl → publish.blogger.publishedUrl %>
    <%# 無 normalized 對應之欄位（保留 legacy 讀法）：date（normalized 僅有 publish.publishedAt，語意不同）、bloggerMode（normalized 無此欄位）、canonicalResolved（含 UTM；normalized.seo.canonicalUrl 為原始 canonical，語意不同） %>
    <%# 不改 HTML 結構 / class name / category 之既有讀法；不改 header / categoryName / builtAt 等非 post 區塊 %>
    <% posts.forEach(function(post) {
      const itemView = post.normalized || {};
      const itemDisplay = itemView.display || {};
      const itemPublish = itemView.publish || {};
      const itemBlogger = itemPublish.blogger || {};
      const itemTitle = itemDisplay.title || post.title;
      const itemDescription = itemDisplay.description || post.description;
      const itemBloggerPublishedUrl = itemBlogger.publishedUrl || post.bloggerPublishedUrl;
    %>
    <li>
      <article class="lab-post-card">
        <h3 class="lab-post-card__title"><%= itemTitle %></h3>
        <% if (itemDescription) { %>
        <p class="lab-post-card__description"><%= itemDescription %></p>
        <% } %>
        <p class="lab-post-card__meta">
          <time datetime="<%= post.date %>"><%= post.date %></time>
          ｜mode: <code><%= post.bloggerMode %></code>
          <% if (itemBloggerPublishedUrl) { %>｜<a href="<%- itemBloggerPublishedUrl %>" rel="noopener noreferrer" target="_blank">已發布</a><% } %>
        </p>
        <% if (post.canonicalResolved) { %>
        <a class="lab-post-card__link" href="<%- post.canonicalResolved %>" rel="noopener noreferrer" target="_blank">前往原文 →</a>
        <% } %>
      </article>
    </li>
    <% }); %>
  </ul>

</div>
