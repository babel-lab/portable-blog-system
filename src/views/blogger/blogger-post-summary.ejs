<%# Phase 3-e-3：Blogger summary 模式 HTML 模板 %>
<%# 摘要導流：顯示 description + CTA 連往 canonical（含 UTM）+ hashtag %>
<%# 不渲染 markdown body 全文（避免內容外洩） %>
<%# Phase 5-f-2：補 in-body canonical link + BlogPosting JSON-LD %>
<%# Phase 8-d-3c-1：低風險欄位改讀 normalized；保留 legacy fallback %>
<%# 模板實際使用之欄位中，僅 title / description 屬本批低風險清單；其餘 contentKind / slug / excerpt / cover / coverAlt 不在模板中，不新增 %>
<%# 不改 canonicalUrl / jsonLd / category / date / author / tags / blocks 之既有讀法 %>
<%
const view = normalized || {};
const display = view.display || {};
const summaryTitle = display.title || post.title;
const summaryDescription = display.description || post.description;
%>
<div class="lab-blogger-article">

  <% if (canonicalUrl) { %>
  <link rel="canonical" href="<%= canonicalUrl %>" />
  <% } %>
  <% if (jsonLd) { %>
  <script type="application/ld+json"><%- JSON.stringify(jsonLd).replace(/</g, '\\u003c') %></script>
  <% } %>

  <header class="lab-article__header">
    <% if (post.category) { %>
    <p class="lab-article__category"><%= post.category %></p>
    <% } %>
    <h1 class="lab-article__title"><%= summaryTitle %></h1>
    <p class="lab-article__meta">
      <% if (post.date) { %>
      <time datetime="<%= post.date %>"><%= post.date %></time>
      <% } %>
      <% if (post.author) { %>
       · <span><%= post.author %></span>
      <% } %>
    </p>
  </header>

  <div class="lab-article__body">
    <p><%= summaryDescription || '（本文為導流摘要，完整內容請見原站。）' %></p>
  </div>

  <% if (canonicalUrl) { %>
  <p>
    <a class="lab-button lab-button--primary" href="<%= canonicalUrl %>" rel="noopener noreferrer" target="_blank">
      閱讀完整文章 →
    </a>
  </p>
  <% } else { %>
  <p><em>（無 canonical 連結，請補上 frontmatter <code>canonical</code> 欄位或 site.config.json <code>githubSiteUrl</code>）</em></p>
  <% } %>

  <% if (post.blocks && post.blocks.hashtags && Array.isArray(post.tags) && post.tags.length > 0) { %>
  <ul class="lab-hashtags">
    <% post.tags.forEach(function(tag) { %>
    <li><span class="lab-hashtag">#<%= tag %></span></li>
    <% }); %>
  </ul>
  <% } %>

</div>
