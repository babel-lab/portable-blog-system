            <% contentKindList.forEach(function(k) { %><dt><%= k %></dt><dd><%= contentKindMap[k] %> 篇</dd><% }); %>
          <% } %>
          <dt>categories</dt><dd><%= sys && sys.categories ? sys.categories.total : 0 %> 個</dd>
          <dt>tags</dt><dd><%= sys && sys.tags ? sys.tags.total : 0 %> 個</dd>
