<!doctype html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="robots" content="noindex, nofollow">
<title>Admin (read-only) — Portable Blog System</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; margin: 0; padding: 1.5rem; line-height: 1.5; color: #222; background: #f5f5f5; }
  h1 { margin: 0 0 0.5rem; font-size: 1.5rem; }
  h2 { margin: 1.25rem 0 0.5rem; font-size: 1.05rem; }
  .admin-banner { background: #fff4cc; border: 1px solid #f0d264; padding: 0.75rem 1rem; border-radius: 4px; margin-bottom: 1rem; font-weight: 600; }
  .admin-banner small { font-weight: 400; color: #666; }
  .admin-meta { color: #555; font-size: 0.85em; margin-bottom: 1rem; padding: 0.5rem 0.75rem; background: #fff; border: 1px solid #ddd; border-radius: 4px; }
  .stats { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; font-size: 0.85em; }
  .stat-card { background: #fff; border: 1px solid #ddd; border-radius: 4px; padding: 0.5rem 0.75rem; min-width: 7rem; }
  .stat-card strong { display: block; font-size: 1.2em; color: #004085; }
  .controls { background: #fff; border: 1px solid #ddd; padding: 0.75rem 1rem; border-radius: 4px; margin-bottom: 1rem; display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; font-size: 0.9em; }
  .controls label { display: flex; align-items: center; gap: 0.4rem; }
  .controls input[type="search"] { padding: 0.35rem 0.6rem; border: 1px solid #bbb; border-radius: 3px; min-width: 18rem; font-size: 0.95em; }
  .controls select { padding: 0.35rem 0.5rem; border: 1px solid #bbb; border-radius: 3px; font-size: 0.95em; background: #fff; }
  .controls .visible-count { color: #555; margin-left: auto; }
  table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid #ddd; font-size: 0.85em; }
  th, td { padding: 0.45rem 0.6rem; border-bottom: 1px solid #eee; text-align: left; vertical-align: top; }
  th { background: #ececec; font-weight: 600; position: sticky; top: 0; z-index: 1; }
  tr.post-row { cursor: pointer; }
  tr.post-row:hover td { background: #fafafa; }
  tr.post-row.is-open td { background: #e8f4ff; }
  tr.post-detail td { background: #fafafa; padding: 0.75rem 1rem 1rem; border-bottom: 2px solid #ccc; }
  .badge { display: inline-block; padding: 1px 7px; border-radius: 10px; font-size: 0.78em; font-weight: 600; margin: 1px 2px 1px 0; line-height: 1.6; white-space: nowrap; }
  .b-ok { background: #d4edda; color: #155724; }
  .b-missing { background: #f8d7da; color: #721c24; }
  .b-draft { background: #fff3cd; color: #856404; }
  .b-ready { background: #cce5ff; color: #004085; }
  .b-published { background: #c3e6cb; color: #0a3622; }
  .b-info { background: #e2e3e5; color: #383d41; }
  .b-tag { background: #e6f0ff; color: #003366; }
  .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.85em; word-break: break-all; }
  .text-muted { color: #999; }
  .empty { color: #999; font-style: italic; }
  .detail-grid { display: grid; grid-template-columns: 12rem 1fr; gap: 0.25rem 1rem; margin-top: 0.5rem; font-size: 0.85em; }
  .detail-grid dt { font-weight: 600; color: #444; }
  .detail-grid dd { margin: 0; word-break: break-all; }
  .detail-section { margin-bottom: 0.75rem; }
  .detail-section h3 { margin: 0.5rem 0 0.25rem; font-size: 0.95em; color: #004085; border-bottom: 1px solid #ccd; padding-bottom: 2px; }
  .completeness-summary { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.25rem; }
  .toggle-hint { color: #999; font-size: 0.78em; margin-left: 0.5rem; }
  .toggle-hint::before { content: "▶ "; }
  tr.post-row.is-open .toggle-hint::before { content: "▼ "; }
  .col-narrow { white-space: nowrap; }
  .col-urls { max-width: 22rem; }
  /* Admin-2-b-1 dry-run viewer */
  .dry-run-section { border: 2px dashed #f0d264; background: #fffbe6; padding: 0.75rem; border-radius: 4px; margin-top: 0.75rem; }
  .dry-run-section h3 { color: #856404; border-bottom-color: #f0d264; }
  .dry-run-warning { background: #fff4cc; border: 1px solid #f0d264; padding: 0.4rem 0.6rem; border-radius: 3px; margin: 0.25rem 0; font-weight: 600; color: #856404; font-size: 0.85em; }
  .dry-run-toggle { padding: 0.35rem 0.75rem; border: 1px solid #999; background: #fff; border-radius: 3px; cursor: pointer; font-size: 0.85em; font-weight: 600; }
  .dry-run-toggle:hover { background: #f0f0f0; }
  .dry-run-form { margin-top: 0.5rem; }
  .dry-run-form table { font-size: 0.82em; }
  .dry-run-form th { background: #f5e8b8; }
  .dry-run-form textarea { width: 100%; box-sizing: border-box; font-family: inherit; font-size: 0.9em; padding: 0.25rem 0.4rem; border: 1px solid #bbb; border-radius: 3px; resize: vertical; }
  .dry-run-compute { padding: 0.35rem 0.75rem; border: 1px solid #856404; background: #ffeb99; border-radius: 3px; cursor: pointer; font-size: 0.85em; font-weight: 600; color: #856404; margin-top: 0.5rem; }
  .dry-run-compute:hover { background: #f0d264; }
  .dry-run-result table { font-size: 0.82em; }
  .dry-run-result .changed-count { font-weight: 700; color: #856404; }
  .dry-run-result .status-changed { color: #d63384; font-weight: 600; }
  .dry-run-result .status-unchanged { color: #155724; }
  .dry-run-result .status-empty { color: #999; font-style: italic; }
  .dry-run-old-value, .dry-run-new-value { max-width: 16rem; word-break: break-word; white-space: pre-wrap; }
</style>
</head>
<body>
  <div class="admin-banner">
    🔒 READ-ONLY ADMIN
    <small>
      — 本機開發檢視；不公開；不寫入任何資料；不部署到 GitHub Pages；prod build 不產出此頁。
    </small>
  </div>

  <h1>Posts (read-only)</h1>

  <div class="admin-meta">
    <strong>產生時間：</strong><span class="mono"><%= builtAt %></span> |
    <strong>來源：</strong>本機 source content <%= posts.length %> 筆（含 draft / ready / published 等所有狀態）|
    <strong>模式：</strong>dev-mode-only（Plan B；prod build 跳過）
  </div>

  <%
    // 統計摘要
    const total = posts.length;
    const byStatus = { ready: 0, draft: 0, published: 0, other: 0 };
    let bloggerEnabled = 0, githubEnabled = 0, fbExists = 0;
    let seoOk = 0, urlOk = 0;
    // sourceSite = 文章來源（content/{site}/posts/）；與 publishTargets enabled 概念不同
    let srcBlogger = 0, srcGithub = 0;
    // Phase 20260520-c-4: fbPublished completeness（fb.enabled=false 或 fbPostUrl/fbPostedAt 有值 → ok）
    let fbPublishedOk = 0;
    posts.forEach(function(p) {
      const s = (p.status === 'ready' || p.status === 'draft' || p.status === 'published') ? p.status : 'other';
      byStatus[s] = (byStatus[s] || 0) + 1;
      if (p.sourceSite === 'blogger') srcBlogger++;
      else if (p.sourceSite === 'github') srcGithub++;
      if (p.blogger.enabled) bloggerEnabled++;
      if (p.github.enabled) githubEnabled++;
      if (p.fbExists) fbExists++;
      if (p.completeness.seo === 'ok') seoOk++;
      if (p.completeness.url === 'ok') urlOk++;
      if (p.completeness.fbPublished === 'ok') fbPublishedOk++;
    });
  %>

  <div class="stats">
    <div class="stat-card"><strong><%= total %></strong>total posts</div>
    <div class="stat-card"><strong><%= byStatus.ready %></strong>ready</div>
    <div class="stat-card"><strong><%= byStatus.draft %></strong>draft</div>
    <div class="stat-card"><strong><%= byStatus.published %></strong>published</div>
    <div class="stat-card" title="原始資料來源標記為 Blogger 的文章數；不等於已輸出或已發布。"><strong><%= srcBlogger %></strong>blogger source</div>
    <div class="stat-card" title="原始資料來源標記為 GitHub 的文章數；不等於已輸出或已部署。"><strong><%= srcGithub %></strong>github source</div>
    <div class="stat-card" title="設定為會輸出到 Blogger 的文章數；不等於 Blogger 已發布成功。"><strong><%= bloggerEnabled %></strong>blogger enabled</div>
    <div class="stat-card" title="設定為會輸出到 GitHub Pages 的文章數；不等於線上頁面已部署完成。"><strong><%= githubEnabled %></strong>github enabled</div>
    <div class="stat-card"><strong><%= fbExists %></strong>has .fb.md</div>
    <div class="stat-card"><strong><%= seoOk %></strong>SEO ok</div>
    <div class="stat-card"><strong><%= urlOk %></strong>URL ok</div>
    <div class="stat-card" title="fb.enabled=false 或 fbPostUrl/fbPostedAt 有值之文章數；per docs/fb-sidecar-schema.md §3.5.5 P3"><strong><%= fbPublishedOk %></strong>fb published ok</div>
  </div>

  <% if (posts.length === 0) { %>
    <p class="empty">無 posts 可顯示（content/{github,blogger}/posts/*.md 為空）</p>
  <% } else { %>
  <div class="controls">
    <label>
      🔎
      <input type="search" id="admin-search" placeholder="搜尋 title / slug / category / tags" autocomplete="off">
    </label>
    <label>
      篩選：
      <select id="admin-filter">
        <option value="all">all</option>
        <optgroup label="status">
          <option value="status:ready">status: ready</option>
          <option value="status:draft">status: draft</option>
          <option value="status:published">status: published</option>
        </optgroup>
        <optgroup label="channel">
          <option value="blogger:enabled">Blogger enabled</option>
          <option value="blogger:disabled">Blogger disabled</option>
          <option value="github:enabled">GitHub enabled</option>
          <option value="github:disabled">GitHub disabled</option>
        </optgroup>
        <optgroup label="completeness">
          <option value="completeness:seo-missing">SEO missing</option>
          <option value="completeness:fb-missing">FB missing</option>
          <option value="completeness:url-missing">publishedUrl missing</option>
          <option value="completeness:categoryTags-missing">category/tags missing</option>
          <option value="completeness:fbPublished-missing">FB published missing</option>
        </optgroup>
        <optgroup label="contentKind">
          <option value="kind:post">contentKind: post</option>
          <option value="kind:page">contentKind: page</option>
          <option value="kind:tech-note">contentKind: tech-note</option>
          <option value="kind:book-review">contentKind: book-review</option>
          <option value="kind:download">contentKind: download</option>
        </optgroup>
      </select>
    </label>
    <button type="button" id="admin-show-all-toggle" style="padding: 0.35rem 0.7rem; border: 1px solid #bbb; border-radius: 3px; background: #fff; cursor: pointer; font-size: 0.9em;" hidden>Show all</button>
    <span class="visible-count" id="admin-visible-count">showing <%= total %> of <%= total %> matched (<%= total %> total)</span>
  </div>

  <table id="admin-table">
    <thead>
      <tr>
        <th>id / title</th>
        <th class="col-narrow">kind / status</th>
        <th>category / tags</th>
        <th>Blogger</th>
        <th>GitHub</th>
        <th class="col-narrow">Completeness</th>
        <th class="col-urls">URLs</th>
      </tr>
    </thead>
    <tbody>
      <% posts.forEach(function(p, idx) {
        const searchBlob = [p.title, p.titleEn, p.slug, p.category, p.id, ...(p.tags || [])].join(' ').toLowerCase();
        const statusVal = (p.status === 'ready' || p.status === 'draft' || p.status === 'published') ? p.status : 'other';
      %>
      <tr class="post-row"
          data-idx="<%= idx %>"
          data-search="<%= searchBlob %>"
          data-status="<%= statusVal %>"
          data-blogger="<%= p.blogger.enabled ? 'enabled' : 'disabled' %>"
          data-github="<%= p.github.enabled ? 'enabled' : 'disabled' %>"
          data-seo="<%= p.completeness.seo %>"
          data-fb="<%= p.completeness.fb %>"
          data-url="<%= p.completeness.url %>"
          data-cat-tags="<%= p.completeness.categoryTags %>"
          data-fb-published="<%= p.completeness.fbPublished %>"
          data-content-kind="<%= p.contentKind || '' %>">
        <td>
          <% if (p.title) { %><strong><%= p.title %></strong><% } else { %><span class="empty">(empty)</span><% } %>
          <span class="toggle-hint"></span>
          <% if (p.titleEn) { %><br><span class="text-muted"><%= p.titleEn %></span><% } %>
          <br><span class="mono text-muted"><%= p.id || '(empty)' %></span>
          <br><span class="mono text-muted">slug: <%= p.slug || '(empty)' %></span>
          <br><span class="mono text-muted" title="<%= p.publishedSource ? 'source: ' + p.publishedSource : 'no publishedAt source' %>">published: <%= p.publishedAt || '(empty)' %><% if (p.publishedSource) { %> <span class="text-muted" style="font-size: 0.85em;">(<%= p.publishedSource %>)</span><% } %></span>
        </td>
        <td class="col-narrow">
          <% if (p.contentKind) { %>
            <span class="badge b-info"><%= p.contentKind %></span>
          <% } else { %>
            <span class="badge b-missing">no kind</span>
          <% } %>
          <br>
          <% if (p.status === 'ready') { %><span class="badge b-ready">ready</span>
          <% } else if (p.status === 'draft' || p.draft) { %><span class="badge b-draft">draft</span>
          <% } else if (p.status === 'published') { %><span class="badge b-published">published</span>
          <% } else { %><span class="badge b-missing"><%= p.status || 'no status' %></span><% } %>
          <br><span class="text-muted mono">src: <%= p.sourceSite %></span>
          <%# Phase 20260520-fb-p5-a：FB sidecar derived status badge（per docs/fb-sidecar-metadata-pre-analysis.md §6.2） -%>
          <%
            var fbBadgeClass = 'b-info';
            if (p.fbBadge === 'posted') { fbBadgeClass = 'b-published'; }
            else if (p.fbBadge === 'ready') { fbBadgeClass = 'b-ready'; }
            else if (p.fbBadge === 'none' || p.fbBadge === 'disabled') { fbBadgeClass = 'b-info'; }
            else { fbBadgeClass = 'b-draft'; }
          -%>
          <br><span class="badge <%= fbBadgeClass %>" title="FB sidecar derived status；per Phase 20260520-fb-p5-a；none=檔案不存在 / disabled=enabled=false / posted=已發文 / ready=已啟用待發 / 其他=照 status 顯示">FB: <%= p.fbBadge %></span>
        </td>
        <td>
          <% if (p.category) { %><span class="badge b-info"><%= p.category %></span>
          <% } else { %><span class="badge b-missing">no category</span><% } %>
          <% if (p.tags.length > 0) { %><br>
            <% p.tags.forEach(function(t) { %><span class="badge b-tag">#<%= t %></span><% }); %>
          <% } else { %><br><span class="badge b-missing">no tags</span><% } %>
        </td>
        <td>
          <% if (p.blogger.enabled) { %>
            <span class="badge b-ok">enabled</span>
            <% if (p.blogger.mode) { %><span class="badge b-info"><%= p.blogger.mode %></span><% } %>
            <br>
            <% if (p.blogger.publishedUrl) { %><span class="badge b-published">published</span>
            <% } else { %><span class="badge b-missing">no URL</span><% } %>
          <% } else { %><span class="badge b-info">disabled</span><% } %>
        </td>
        <td>
          <% if (p.github.enabled) { %>
            <span class="badge b-ok">enabled</span>
            <% if (p.github.mode) { %><span class="badge b-info"><%= p.github.mode %></span><% } %>
          <% } else { %><span class="badge b-info">disabled</span><% } %>
        </td>
        <td class="col-narrow">
          <span class="badge <%= p.completeness.seo === 'ok' ? 'b-ok' : 'b-missing' %>">SEO <%= p.completeness.seo %></span><br>
          <span class="badge <%= p.completeness.fb === 'ok' ? 'b-ok' : 'b-missing' %>">FB <%= p.completeness.fb %></span><br>
          <span class="badge <%= p.completeness.blogger === 'ok' ? 'b-ok' : 'b-missing' %>">Blogger <%= p.completeness.blogger %></span><br>
          <span class="badge <%= p.completeness.github === 'ok' ? 'b-ok' : 'b-missing' %>">GitHub <%= p.completeness.github %></span><br>
          <span class="badge <%= p.completeness.url === 'ok' ? 'b-ok' : 'b-missing' %>">URL <%= p.completeness.url %></span><br>
          <span class="badge <%= p.completeness.categoryTags === 'ok' ? 'b-ok' : 'b-missing' %>">cat/tags <%= p.completeness.categoryTags %></span><br>
          <span class="badge <%= p.completeness.fbPublished === 'ok' ? 'b-ok' : 'b-missing' %>" title="fb.enabled=false 或 fbPostUrl/fbPostedAt 有值 → ok；fb.enabled=true 但兩欄位皆空 → missing">FB pub <%= p.completeness.fbPublished %></span>
        </td>
        <td class="col-urls">
          <% if (p.blogger.publishedUrl) { %><div class="mono">📘 <a href="<%= p.blogger.publishedUrl %>" target="_blank" rel="noopener noreferrer"><%= p.blogger.publishedUrl %></a></div><% } %>
          <% if (p.github.previewUrl) { %><div class="mono">🐙 <a href="<%= p.github.previewUrl %>" target="_blank" rel="noopener noreferrer"><%= p.github.previewUrl %></a></div><% } %>
          <% if (!p.blogger.publishedUrl && !p.github.previewUrl) { %><span class="text-muted">(empty)</span><% } %>
        </td>
      </tr>
      <tr class="post-detail" data-idx="<%= idx %>" hidden>
        <td colspan="7">
          <div class="detail-section">
            <h3>Identity</h3>
            <dl class="detail-grid">
              <dt>id</dt><dd class="mono"><%= p.id || '(empty)' %></dd>
              <dt>title</dt><dd><%= p.title || '(empty)' %></dd>
              <dt>titleEn</dt><dd><%= p.titleEn || '(empty)' %></dd>
              <dt>slug</dt><dd class="mono"><%= p.slug || '(empty)' %></dd>
              <dt>contentKind</dt><dd class="mono"><%= p.contentKind || '(empty)' %></dd>
              <dt>primaryPlatform</dt><dd class="mono"><%= p.primaryPlatform || '(empty)' %></dd>
              <dt>sourceSite</dt><dd class="mono"><%= p.sourceSite %></dd>
              <dt>status</dt><dd><%= p.status || '(empty)' %><% if (p.draft) { %> / draft=true<% } %></dd>
              <dt>category</dt><dd><%= p.category || '(empty)' %></dd>
              <dt>tags</dt><dd><% if (p.tags.length > 0) { p.tags.forEach(function(t) { %><span class="badge b-tag">#<%= t %></span><% }); } else { %>(empty)<% } %></dd>
            </dl>
          </div>

          <div class="detail-section">
            <h3>Dates</h3>
            <dl class="detail-grid">
              <dt>publishedAt (canonical)</dt><dd class="mono"><%= p.publishedAt || '(empty)' %></dd>
              <dt>publishedSource</dt><dd class="mono"><%= p.publishedSource || '(empty)' %></dd>
              <dt>dateIntent (frontmatter.date)</dt><dd class="mono"><%= p.dateIntent || '(empty)' %></dd>
              <dt>updatedAt (frontmatter.updated)</dt><dd class="mono"><%= p.updatedAt || '(empty)' %></dd>
            </dl>
            <p class="text-muted" style="font-size: 0.85em; margin: 0.25rem 0 0;">
              注：publishedAt 為 canonical fallback chain（blogger.publishedAt → github.publishedAt → frontmatter.date）；列表排序以此欄位為主，fallback 至 id desc。
            </p>
          </div>

          <div class="detail-section">
            <h3>SEO</h3>
            <dl class="detail-grid">
              <dt>description</dt><dd><%= p.description || '(empty)' %></dd>
              <dt>searchDescription</dt><dd><%= p.searchDescription || '(empty)' %></dd>
              <dt>cover</dt><dd class="mono"><%= p.cover || '(empty)' %></dd>
              <dt>coverAlt</dt><dd><%= p.coverAlt || '(empty)' %></dd>
            </dl>
          </div>

          <div class="detail-section">
            <h3>Blogger channel</h3>
            <dl class="detail-grid">
              <dt>publishTargets.enabled</dt><dd><%= p.blogger.enabled %></dd>
              <dt>publishTargets.mode</dt><dd class="mono"><%= p.blogger.mode || '(empty)' %></dd>
              <dt>blogger.type</dt><dd class="mono"><%= p.blogger.type || '(empty)' %></dd>
              <dt>blogger.status</dt><dd class="mono"><%= p.blogger.status || '(empty)' %></dd>
              <dt>blogger.permalink</dt><dd class="mono"><%= p.blogger.permalink || '(empty)' %></dd>
              <dt>blogger.publishedUrl</dt><dd class="mono"><% if (p.blogger.publishedUrl) { %><a href="<%= p.blogger.publishedUrl %>" target="_blank" rel="noopener noreferrer"><%= p.blogger.publishedUrl %></a><% } else { %>(empty)<% } %></dd>
            </dl>
          </div>

          <div class="detail-section">
            <h3>GitHub channel</h3>
            <dl class="detail-grid">
              <dt>publishTargets.enabled</dt><dd><%= p.github.enabled %></dd>
              <dt>publishTargets.mode</dt><dd class="mono"><%= p.github.mode || '(empty)' %></dd>
              <dt>github.path</dt><dd class="mono"><%= p.github.path || '(empty)' %></dd>
              <dt>github.previewUrl</dt><dd class="mono"><% if (p.github.previewUrl) { %><a href="<%= p.github.previewUrl %>" target="_blank" rel="noopener noreferrer"><%= p.github.previewUrl %></a><% } else { %>(empty)<% } %></dd>
            </dl>
          </div>

          <div class="detail-section">
            <h3>FB promotion (.fb.md sidecar)</h3>
            <dl class="detail-grid">
              <dt>sidecar exists</dt><dd><%= p.fbExists %></dd>
              <dt>enabled flag</dt><dd><%= p.fbEnabled %></dd>
            </dl>
            <p class="text-muted" style="font-size: 0.85em; margin: 0.25rem 0 0;">
              注：本批 read-only 僅讀 .fb.md 之 frontmatter <code>enabled</code> 旗標；不解析 hashtags / body / UTM 等內容欄位。
            </p>
          </div>

          <div class="detail-section">
            <h3>FB Post (read-only metadata)</h3>
            <%
              var fbDetailBadgeClass = 'b-info';
              if (p.fbBadge === 'posted') { fbDetailBadgeClass = 'b-published'; }
              else if (p.fbBadge === 'ready') { fbDetailBadgeClass = 'b-ready'; }
              else if (p.fbBadge === 'none' || p.fbBadge === 'disabled') { fbDetailBadgeClass = 'b-info'; }
              else { fbDetailBadgeClass = 'b-draft'; }
            -%>
            <dl class="detail-grid">
              <dt>exists</dt><dd><%= p.fbExists %></dd>
              <dt>enabled</dt><dd><%= p.fbEnabled %></dd>
              <dt>status</dt><dd class="mono"><%= p.fbStatus || '(empty)' %></dd>
              <dt>badge (derived)</dt><dd><span class="badge <%= fbDetailBadgeClass %>">FB: <%= p.fbBadge %></span></dd>
              <dt>fbPostUrl</dt><dd class="mono"><% if (p.fbPostUrl) { %><a href="<%= p.fbPostUrl %>" target="_blank" rel="noopener noreferrer"><%= p.fbPostUrl %> ↗</a><% } else { %>(empty)<% } %></dd>
              <dt>fbPostedAt</dt><dd class="mono"><%= p.fbPostedAt || '(empty)' %></dd>
              <dt>campaign</dt><dd class="mono"><%= p.fbCampaign || '(empty)' %></dd>
              <dt>audience</dt><dd class="mono"><%= p.fbAudience || '(empty)' %></dd>
              <dt>title</dt><dd><%= p.fbTitle || '(empty)' %></dd>
              <dt>titleEn</dt><dd><%= p.fbTitleEn || '(empty)' %></dd>
              <dt>hashtags</dt><dd><% if (Array.isArray(p.fbHashtags) && p.fbHashtags.length > 0) { p.fbHashtags.forEach(function(h) { %><span class="badge b-tag"><%= h %></span><% }); } else { %>(empty)<% } %></dd>
              <dt>imageUrl</dt><dd class="mono"><% if (p.fbImageUrl) { %><a href="<%= p.fbImageUrl %>" target="_blank" rel="noopener noreferrer"><%= p.fbImageUrl %> ↗</a><% } else { %>(empty)<% } %></dd>
              <dt>note</dt><dd><%= p.fbNote || '(empty)' %></dd>
              <dt>fbPostId <span class="text-muted" style="font-size: 0.85em;">(debug; Graph API 預備)</span></dt><dd class="mono" style="font-size: 0.85em;"><%= p.fbPostId || '(empty)' %></dd>
            </dl>
            <p class="text-muted" style="font-size: 0.85em; margin: 0.25rem 0 0;">
              注：Phase 20260520-fb-p5-a 補讀 7 個 read-only 欄位（status / audience / title / titleEn / hashtags / imageUrl / note）+ derived badge（per <code>docs/fb-sidecar-metadata-pre-analysis.md</code> §3 / §6）。Admin 仍嚴格 read-only；無 write / form submit / fs API；postId 為 Graph API 預備 debug 欄位（per §6 顯示建議）。4 個 fb post URL 欄位已於 Phase 20260520-c-2 正式收編至 <code>docs/fb-sidecar-schema.md</code> §3.1 / §3.5；fbPostUrl 為作者於 FB 發佈後手動回填之 FB 貼文 URL（指回 FB），與 <code>finalUrl</code>（FB 貼文 body 內之 Blogger / GitHub article 最終 URL；從 FB 出去）為兩個不同概念，不可混用。imageUrl 採外連連結（不直接載入圖片）以避免畫面雜亂。
            </p>
          </div>

          <%# Phase 20260520-fb-p5-b：FB sidecar dry-run editor（client-side only；無 fs.write / fetch / form submit / Apply button） -%>
          <%# - 使用 fb- prefix class 避免與既有 SEO dry-run viewer 之 .dry-run-section / .dry-run-toggle 衝突 -%>
          <%# - 12 個欄位：enabled / status / postUrl / postedAt / postId / campaign / audience / title / titleEn / hashtags / imageUrl / note -%>
          <%# - hashtags 採 textarea 一行一個；split by \n 後 normalize + JSON.stringify 比對 -%>
          <%# - inline style 避免動 <style> block；視覺用藍色 tint 與既有黃色 SEO dry-run 區分 -%>
          <div class="detail-section fb-dry-run-section" data-post-idx="<%= idx %>" style="border: 2px dashed #6c8ebf; background: #f0f4fa; padding: 0.75rem; border-radius: 4px; margin-top: 0.75rem;">
            <h3 style="color: #2c5282; border-bottom: 1px solid #c5d6e8;">FB Sidecar Dry-run Editor</h3>
            <p style="background: #d6e4f5; border: 1px solid #6c8ebf; padding: 0.4rem 0.6rem; border-radius: 3px; margin: 0.25rem 0; font-weight: 600; color: #2c5282; font-size: 0.85em;">⚠️ Dry-run only. No file will be written. 這只是 dry-run 預覽，不會寫入任何 .fb.md 檔案。需要的話請手動複製結果。</p>
            <p style="font-size: 0.82em; color: #555; margin: 0.25rem 0 0.5rem;">支援 12 個欄位（enabled / status / postUrl / postedAt / postId / campaign / audience / title / titleEn / hashtags / imageUrl / note）；read-only preview；無 form submit / 無 fs API / 無 fetch。實際寫入留待 FB-P5-c phase；當前請手動編輯 .fb.md。</p>
            <button type="button" class="fb-dry-run-toggle" style="padding: 0.35rem 0.75rem; border: 1px solid #999; background: #fff; border-radius: 3px; cursor: pointer; font-size: 0.85em; font-weight: 600;">Edit FB Metadata</button>
            <button type="button" class="fb-dry-run-cancel" hidden style="padding: 0.35rem 0.75rem; border: 1px solid #999; background: #fff; border-radius: 3px; cursor: pointer; font-size: 0.85em; font-weight: 600; margin-left: 0.5rem;">Cancel FB Edit</button>
            <div class="fb-dry-run-form" hidden style="margin-top: 0.5rem;">
              <table style="font-size: 0.82em; width: 100%;">
                <thead><tr style="background: #d6e4f5;"><th style="width:9rem">field</th><th style="width:35%">current value</th><th>new value（編輯此欄即可）</th></tr></thead>
                <tbody>
                  <tr><td class="mono">enabled</td><td class="fb-dry-run-old-value" data-fb-field="enabled" data-current="<%= p.fbEnabled ? 'true' : 'false' %>"><%= p.fbEnabled ? 'true' : 'false' %></td><td><select data-fb-input="enabled" style="width: 100%; padding: 0.25rem; font-family: inherit;"><option value="true"<%= p.fbEnabled ? ' selected' : '' %>>true</option><option value="false"<%= !p.fbEnabled ? ' selected' : '' %>>false</option></select></td></tr>
                  <tr><td class="mono">status</td><td class="fb-dry-run-old-value" data-fb-field="status" data-current="<%= p.fbStatus %>"><%= p.fbStatus || '(empty)' %></td><td><input type="text" data-fb-input="status" value="<%= p.fbStatus %>" placeholder="draft / ready / posted / archived" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">postUrl</td><td class="fb-dry-run-old-value" data-fb-field="postUrl" data-current="<%= p.fbPostUrl %>"><%= p.fbPostUrl || '(empty)' %></td><td><input type="text" data-fb-input="postUrl" value="<%= p.fbPostUrl %>" placeholder="https://www.facebook.com/..." style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">postedAt</td><td class="fb-dry-run-old-value" data-fb-field="postedAt" data-current="<%= p.fbPostedAt %>"><%= p.fbPostedAt || '(empty)' %></td><td><input type="text" data-fb-input="postedAt" value="<%= p.fbPostedAt %>" placeholder="ISO 8601 或 YYYY-MM-DD HH:mm" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">postId</td><td class="fb-dry-run-old-value" data-fb-field="postId" data-current="<%= p.fbPostId %>"><%= p.fbPostId || '(empty)' %></td><td><input type="text" data-fb-input="postId" value="<%= p.fbPostId %>" placeholder="optional (Graph API)" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">campaign</td><td class="fb-dry-run-old-value" data-fb-field="campaign" data-current="<%= p.fbCampaign %>"><%= p.fbCampaign || '(empty)' %></td><td><input type="text" data-fb-input="campaign" value="<%= p.fbCampaign %>" placeholder="人工分類標記" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">audience</td><td class="fb-dry-run-old-value" data-fb-field="audience" data-current="<%= p.fbAudience %>"><%= p.fbAudience || '(empty)' %></td><td><input type="text" data-fb-input="audience" value="<%= p.fbAudience %>" placeholder="developers / parents / educators / ..." style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">title</td><td class="fb-dry-run-old-value" data-fb-field="title" data-current="<%= p.fbTitle %>"><%= p.fbTitle || '(empty)' %></td><td><input type="text" data-fb-input="title" value="<%= p.fbTitle %>" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">titleEn</td><td class="fb-dry-run-old-value" data-fb-field="titleEn" data-current="<%= p.fbTitleEn %>"><%= p.fbTitleEn || '(empty)' %></td><td><input type="text" data-fb-input="titleEn" value="<%= p.fbTitleEn %>" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">hashtags<br><small style="color: #777; font-size: 0.85em;">(一行一個)</small></td><td class="fb-dry-run-old-value" data-fb-field="hashtags" data-current="<%= Array.isArray(p.fbHashtags) ? p.fbHashtags.join('\n') : '' %>" style="white-space: pre-wrap;"><% if (Array.isArray(p.fbHashtags) && p.fbHashtags.length > 0) { %><%= p.fbHashtags.join('\n') %><% } else { %>(empty)<% } %></td><td><textarea data-fb-input="hashtags" rows="3" placeholder="一行一個 hashtag" style="width: 100%; padding: 0.25rem; font-family: inherit; resize: vertical;"><%= Array.isArray(p.fbHashtags) ? p.fbHashtags.join('\n') : '' %></textarea></td></tr>
                  <tr><td class="mono">imageUrl</td><td class="fb-dry-run-old-value" data-fb-field="imageUrl" data-current="<%= p.fbImageUrl %>"><%= p.fbImageUrl || '(empty)' %></td><td><input type="text" data-fb-input="imageUrl" value="<%= p.fbImageUrl %>" placeholder="https://... (外連；不直接載入)" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">note</td><td class="fb-dry-run-old-value" data-fb-field="note" data-current="<%= p.fbNote %>"><%= p.fbNote || '(empty)' %></td><td><textarea data-fb-input="note" rows="2" style="width: 100%; padding: 0.25rem; font-family: inherit; resize: vertical;"><%= p.fbNote %></textarea></td></tr>
                </tbody>
              </table>
              <button type="button" class="fb-dry-run-compute" style="padding: 0.35rem 0.75rem; border: 1px solid #2c5282; background: #cfe2ff; border-radius: 3px; cursor: pointer; font-size: 0.85em; font-weight: 600; color: #2c5282; margin-top: 0.5rem;">Show FB Dry-run Diff</button>
              <div class="fb-dry-run-result" hidden>
                <p style="margin: 0.5rem 0 0.25rem;">變更欄位數：<span class="fb-dry-run-changed-count" style="font-weight: 700; color: #2c5282;">0</span> / 12</p>
                <table style="font-size: 0.82em; width: 100%;">
                  <thead><tr style="background: #d6e4f5;"><th style="width:8rem">field</th><th>before</th><th>after</th><th style="width:8rem">status</th></tr></thead>
                  <tbody class="fb-dry-run-diff-rows"></tbody>
                </table>
                <details style="margin-top: 0.5rem;"><summary style="cursor: pointer; color: #2c5282; font-size: 0.82em;">Show simulated frontmatter (after)</summary><pre class="fb-dry-run-after" style="background: #fff; border: 1px solid #c5d6e8; padding: 0.4rem; margin-top: 0.25rem; font-size: 0.78em; overflow-x: auto; white-space: pre-wrap;"></pre></details>
                <p style="background: #d6e4f5; border: 1px solid #6c8ebf; padding: 0.4rem 0.6rem; border-radius: 3px; margin-top: 0.5rem; font-weight: 600; color: #2c5282; font-size: 0.85em;">⚠️ Dry-run only. No file will be written. 若需實際寫入：等 FB-P5-c phase 落地；當前請手動編輯 <code>.fb.md</code> 後重 build。</p>
              </div>
            </div>
          </div>

          <div class="detail-section">
            <h3>Related / other links</h3>
            <dl class="detail-grid">
              <dt>relatedLinks 數量</dt><dd><%= p.relatedLinksCount %></dd>
              <dt>otherLinks 數量</dt><dd><%= p.otherLinksCount %></dd>
            </dl>
            <p class="text-muted" style="font-size: 0.85em; margin: 0.25rem 0 0;">
              注：本批僅顯示陣列長度（直接讀 frontmatter）；個別 link 內容 schema 詳見 <code>docs/related-links-schema.md</code>。
            </p>
          </div>

          <div class="detail-section">
            <h3>Completeness summary</h3>
            <div class="completeness-summary">
              <span class="badge <%= p.completeness.seo === 'ok' ? 'b-ok' : 'b-missing' %>">SEO <%= p.completeness.seo %></span>
              <span class="badge <%= p.completeness.fb === 'ok' ? 'b-ok' : 'b-missing' %>">FB <%= p.completeness.fb %></span>
              <span class="badge <%= p.completeness.blogger === 'ok' ? 'b-ok' : 'b-missing' %>">Blogger <%= p.completeness.blogger %></span>
              <span class="badge <%= p.completeness.github === 'ok' ? 'b-ok' : 'b-missing' %>">GitHub <%= p.completeness.github %></span>
              <span class="badge <%= p.completeness.url === 'ok' ? 'b-ok' : 'b-missing' %>">URL <%= p.completeness.url %></span>
              <span class="badge <%= p.completeness.categoryTags === 'ok' ? 'b-ok' : 'b-missing' %>">cat/tags <%= p.completeness.categoryTags %></span>
              <span class="badge <%= p.completeness.fbPublished === 'ok' ? 'b-ok' : 'b-missing' %>">FB pub <%= p.completeness.fbPublished %></span>
            </div>
          </div>

          <% if (p.missingFields && p.missingFields.length > 0) { %>
          <div class="detail-section">
            <h3>Missing fields（建議補齊）</h3>
            <div class="completeness-summary">
              <% p.missingFields.forEach(function(f) { %><span class="badge b-missing"><%= f %></span><% }); %>
            </div>
          </div>
          <% } else { %>
          <div class="detail-section">
            <h3>Missing fields</h3>
            <p style="margin: 0;"><span class="badge b-ok">所有檢查欄位齊全</span></p>
          </div>
          <% } %>

          <div class="detail-section dry-run-section" data-post-idx="<%= idx %>">
            <h3>Dry-run edit (no write)</h3>
            <p class="dry-run-warning">⚠️ Dry-run only. No file will be written. 此功能僅計算 + 顯示變更差異；任何實際寫入請以 VS Code + git workflow 處理。</p>
            <p style="font-size: 0.82em; color: #555; margin: 0.25rem 0 0.5rem;">支援欄位（per <code>docs/admin-2-write-pre-analysis.md</code> §4.1 safe editable subset）：description / searchDescription / titleEn / coverAlt</p>
            <button type="button" class="dry-run-toggle">Start Edit</button>
            <div class="dry-run-form" hidden>
              <table>
                <thead>
                  <tr><th style="width:9rem">field</th><th style="width:40%">current value</th><th>new value（編輯此欄即可）</th></tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="mono">description</td>
                    <td class="dry-run-old-value" data-field="description" data-current="<%= p.description %>"><%= p.description || '(empty)' %></td>
                    <td><textarea data-input="description" rows="2"><%= p.description %></textarea></td>
                  </tr>
                  <tr>
                    <td class="mono">searchDescription</td>
                    <td class="dry-run-old-value" data-field="searchDescription" data-current="<%= p.searchDescription %>"><%= p.searchDescription || '(empty)' %></td>
                    <td><textarea data-input="searchDescription" rows="2"><%= p.searchDescription %></textarea></td>
                  </tr>
                  <tr>
                    <td class="mono">titleEn</td>
                    <td class="dry-run-old-value" data-field="titleEn" data-current="<%= p.titleEn %>"><%= p.titleEn || '(empty)' %></td>
                    <td><textarea data-input="titleEn" rows="1"><%= p.titleEn %></textarea></td>
                  </tr>
                  <tr>
                    <td class="mono">coverAlt</td>
                    <td class="dry-run-old-value" data-field="coverAlt" data-current="<%= p.coverAlt %>"><%= p.coverAlt || '(empty)' %></td>
                    <td><textarea data-input="coverAlt" rows="1"><%= p.coverAlt %></textarea></td>
                  </tr>
                </tbody>
              </table>
              <button type="button" class="dry-run-compute">Show Dry-run Diff</button>
              <div class="dry-run-result" hidden>
                <p style="margin: 0.5rem 0 0.25rem;">變更欄位數：<span class="changed-count">0</span> / 4</p>
                <table>
                  <thead>
                    <tr><th style="width:9rem">field</th><th>old</th><th>new</th><th style="width:9rem">status</th></tr>
                  </thead>
                  <tbody class="dry-run-diff-rows"></tbody>
                </table>
                <p class="dry-run-warning" style="margin-top: 0.5rem;">⚠️ Dry-run only. No file will be written. 若要實際寫入：VS Code 編輯 source 檔 + <code>git diff</code> + <code>git commit</code>。</p>
              </div>
            </div>
          </div>

          <div class="detail-section">
            <h3>Source path</h3>
            <p class="mono" style="margin: 0;"><%= p.sourcePath %></p>
          </div>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>

  <div class="admin-meta" style="margin-top: 1rem;">
    <strong>說明：</strong>點任一 row 可展開 detail panel；再點一次收合。<br>
    <strong>搜尋：</strong>match title / titleEn / slug / category / id / tags（case-insensitive）。<br>
    <strong>邊界：</strong>本頁屬 read-only；無 form / 無 button writes；不會寫入任何 source 檔案。<br>
    <strong>規格：</strong>詳見 <code>docs/admin-1-readonly-preflight.md</code> / <code>docs/admin-mvp-pre-analysis.md</code>。
  </div>

  <% if (posts.length > 0) { %>
  <script>
    (function () {
      // Phase 20260520-b-4: show-all toggle config
      var SHOW_LIMIT = 20;
      var showAll = false;
      var search = document.getElementById('admin-search');
      var filter = document.getElementById('admin-filter');
      var visibleCount = document.getElementById('admin-visible-count');
      var showAllToggle = document.getElementById('admin-show-all-toggle');
      var rows = Array.prototype.slice.call(document.querySelectorAll('tr.post-row'));
      var details = Array.prototype.slice.call(document.querySelectorAll('tr.post-detail'));

      function matchesFilter(row, f) {
        if (f === 'all' || !f) return true;
        var parts = f.split(':');
        var key = parts[0];
        var val = parts[1];
        switch (key) {
          case 'status': return row.dataset.status === val;
          case 'blogger': return row.dataset.blogger === val;
          case 'github': return row.dataset.github === val;
          case 'kind': return row.dataset.contentKind === val;
          case 'completeness':
            // val 形如 "seo-missing" / "fb-missing" / "url-missing" / "categoryTags-missing"
            if (val === 'seo-missing') return row.dataset.seo === 'missing';
            if (val === 'fb-missing') return row.dataset.fb === 'missing';
            if (val === 'url-missing') return row.dataset.url === 'missing';
            if (val === 'categoryTags-missing') return row.dataset.catTags === 'missing';
            if (val === 'fbPublished-missing') return row.dataset.fbPublished === 'missing';
            return true;
          default: return true;
        }
      }

      // Phase 20260520-b-4：順序 search → filter → limit；toggle 作用於 search/filter 後結果
      function applyFilters() {
        var q = (search.value || '').toLowerCase().trim();
        var f = filter.value;
        var matchedCount = 0;
        var shownCount = 0;
        rows.forEach(function (row, i) {
          var detail = details[i];
          var matches = true;
          if (q && (row.dataset.search || '').indexOf(q) === -1) matches = false;
          if (matches && !matchesFilter(row, f)) matches = false;
          var visible = false;
          if (matches) {
            matchedCount++;
            if (showAll || shownCount < SHOW_LIMIT) {
              visible = true;
              shownCount++;
            }
          }
          row.hidden = !visible;
          if (!visible) {
            // 收合 detail 並移除 is-open
            detail.hidden = true;
            row.classList.remove('is-open');
          }
        });
        visibleCount.textContent = 'showing ' + shownCount + ' of ' + matchedCount + ' matched (' + rows.length + ' total)';
        if (showAllToggle) {
          var needsToggle = matchedCount > SHOW_LIMIT;
          showAllToggle.hidden = !needsToggle;
          showAllToggle.textContent = showAll ? 'Show latest ' + SHOW_LIMIT : 'Show all';
        }
      }

      search.addEventListener('input', applyFilters);
      filter.addEventListener('change', applyFilters);
      if (showAllToggle) {
        showAllToggle.addEventListener('click', function () {
          showAll = !showAll;
          applyFilters();
        });
      }

      // 點 row 展開 / 收合 detail
      rows.forEach(function (row, i) {
        row.addEventListener('click', function () {
          var detail = details[i];
          var nowOpen = detail.hidden;
          detail.hidden = !nowOpen;
          row.classList.toggle('is-open', nowOpen);
        });
      });

      // Initial apply (no filter)
      applyFilters();

      // Phase Admin-2-b-1: dry-run edit viewer handlers
      // 純 client-side：不寫任何檔案；不呼叫 fetch / XHR / fs；無 Apply / Save / Write button。
      // 點 dry-run section 內 button / input 時 stopPropagation 避免冒泡至 row click（toggle detail）。
      function escapeHtml(s) {
        var div = document.createElement('div');
        div.textContent = s == null ? '' : String(s);
        return div.innerHTML;
      }
      var drySections = document.querySelectorAll('.dry-run-section');
      drySections.forEach(function (section) {
        section.addEventListener('click', function (e) { e.stopPropagation(); });
        var toggle = section.querySelector('.dry-run-toggle');
        var form = section.querySelector('.dry-run-form');
        var compute = section.querySelector('.dry-run-compute');
        var result = section.querySelector('.dry-run-result');
        var diffRows = section.querySelector('.dry-run-diff-rows');
        var changedCount = section.querySelector('.changed-count');
        if (!toggle || !form || !compute || !result || !diffRows || !changedCount) return;
        toggle.addEventListener('click', function () {
          form.hidden = !form.hidden;
          toggle.textContent = form.hidden ? 'Start Edit' : 'Cancel';
          if (form.hidden) result.hidden = true;
        });
        compute.addEventListener('click', function () {
          var fields = ['description', 'searchDescription', 'titleEn', 'coverAlt'];
          var changed = 0;
          var html = '';
          fields.forEach(function (name) {
            var oldCell = section.querySelector('[data-field="' + name + '"]');
            var input = section.querySelector('[data-input="' + name + '"]');
            var oldVal = oldCell ? (oldCell.dataset.current || '') : '';
            var newVal = input ? (input.value || '') : '';
            var statusClass, statusText;
            if (oldVal === newVal) {
              if (oldVal === '') { statusClass = 'status-empty'; statusText = 'unchanged / empty'; }
              else { statusClass = 'status-unchanged'; statusText = 'unchanged'; }
            } else {
              statusClass = 'status-changed';
              statusText = 'changed';
              changed++;
            }
            html += '<tr>'
              + '<td class="mono">' + escapeHtml(name) + '</td>'
              + '<td class="dry-run-old-value">' + (oldVal === '' ? '<span class="status-empty">(empty)</span>' : escapeHtml(oldVal)) + '</td>'
              + '<td class="dry-run-new-value">' + (newVal === '' ? '<span class="status-empty">(empty)</span>' : escapeHtml(newVal)) + '</td>'
              + '<td class="' + statusClass + '">' + statusText + '</td>'
              + '</tr>';
          });
          diffRows.innerHTML = html;
          changedCount.textContent = changed;
          result.hidden = false;
        });
      });

      // Phase 20260520-fb-p5-b: FB sidecar dry-run editor handlers
      // 純 client-side：無 fs.write / 無 fetch / 無 XHR / 無 form submit / 無 Apply button。
      // 點 fb-dry-run-section 內 button / input 時 stopPropagation 避免冒泡至 row click（toggle detail）。
      // 與既有 SEO dry-run viewer 使用獨立 .fb-dry-run-* class 不衝突。
      var fbDrySections = document.querySelectorAll('.fb-dry-run-section');
      fbDrySections.forEach(function (section) {
        section.addEventListener('click', function (e) { e.stopPropagation(); });
        var fbToggle = section.querySelector('.fb-dry-run-toggle');
        var fbCancel = section.querySelector('.fb-dry-run-cancel');
        var fbForm = section.querySelector('.fb-dry-run-form');
        var fbCompute = section.querySelector('.fb-dry-run-compute');
        var fbResult = section.querySelector('.fb-dry-run-result');
        var fbDiffRows = section.querySelector('.fb-dry-run-diff-rows');
        var fbChangedCount = section.querySelector('.fb-dry-run-changed-count');
        var fbAfterBlock = section.querySelector('.fb-dry-run-after');
        if (!fbToggle || !fbForm || !fbCompute || !fbResult || !fbDiffRows || !fbChangedCount) return;

        function setFbFormOpen(open) {
          fbForm.hidden = !open;
          fbToggle.hidden = open;
          if (fbCancel) fbCancel.hidden = !open;
          if (!open) fbResult.hidden = true;
        }
        fbToggle.addEventListener('click', function () { setFbFormOpen(true); });
        if (fbCancel) fbCancel.addEventListener('click', function () { setFbFormOpen(false); });

        fbCompute.addEventListener('click', function () {
          var fbFields = [
            { name: 'enabled', type: 'bool' },
            { name: 'status', type: 'string' },
            { name: 'postUrl', type: 'string' },
            { name: 'postedAt', type: 'string' },
            { name: 'postId', type: 'string' },
            { name: 'campaign', type: 'string' },
            { name: 'audience', type: 'string' },
            { name: 'title', type: 'string' },
            { name: 'titleEn', type: 'string' },
            { name: 'hashtags', type: 'array' },
            { name: 'imageUrl', type: 'string' },
            { name: 'note', type: 'string' },
          ];
          var changedFb = 0;
          var htmlFb = '';
          var afterLines = [];
          fbFields.forEach(function (f) {
            var oldCell = section.querySelector('[data-fb-field="' + f.name + '"]');
            var input = section.querySelector('[data-fb-input="' + f.name + '"]');
            var oldVal = oldCell ? (oldCell.dataset.current || '') : '';
            var newVal = input ? (input.value || '') : '';
            var oldDisp = oldVal;
            var newDisp = newVal;
            var isEqual;
            if (f.type === 'array') {
              var splitNorm = function (s) {
                return s.split(/\r?\n/).map(function(x){return x.trim();}).filter(function(x){return x !== '';});
              };
              var oldArr = oldVal === '' ? [] : splitNorm(oldVal);
              var newArr = splitNorm(newVal);
              oldDisp = oldArr.join('\n');
              newDisp = newArr.join('\n');
              isEqual = JSON.stringify(oldArr) === JSON.stringify(newArr);
              afterLines.push(f.name + ':');
              if (newArr.length === 0) { afterLines.push('  []'); }
              else { newArr.forEach(function(h){ afterLines.push('  - "' + h.replace(/"/g, '\\"') + '"'); }); }
            } else if (f.type === 'bool') {
              isEqual = oldVal === newVal;
              afterLines.push(f.name + ': ' + (newVal === 'true' ? 'true' : 'false'));
            } else {
              isEqual = oldVal === newVal;
              afterLines.push(f.name + ': "' + newVal.replace(/"/g, '\\"') + '"');
            }
            var statusStyle, statusText;
            if (isEqual) {
              if (oldDisp === '' && newDisp === '') { statusStyle = 'color: #999; font-style: italic;'; statusText = 'unchanged / empty'; }
              else { statusStyle = 'color: #155724;'; statusText = 'unchanged'; }
            } else {
              statusStyle = 'color: #d63384; font-weight: 600;';
              statusText = 'changed';
              changedFb++;
            }
            var emptyMark = '<span style="color:#999;font-style:italic;">(empty)</span>';
            htmlFb += '<tr>'
              + '<td class="mono">' + escapeHtml(f.name) + '</td>'
              + '<td style="max-width: 14rem; word-break: break-word; white-space: pre-wrap;">' + (oldDisp === '' ? emptyMark : escapeHtml(oldDisp)) + '</td>'
              + '<td style="max-width: 14rem; word-break: break-word; white-space: pre-wrap;">' + (newDisp === '' ? emptyMark : escapeHtml(newDisp)) + '</td>'
              + '<td style="' + statusStyle + '">' + statusText + '</td>'
              + '</tr>';
          });
          fbDiffRows.innerHTML = htmlFb;
          fbChangedCount.textContent = changedFb;
          if (fbAfterBlock) fbAfterBlock.textContent = afterLines.join('\n');
          fbResult.hidden = false;
        });
      });
    })();
  </script>
  <% } %>
</body>
</html>
