    <div class="npd-summary-strip" style="margin: 0 0 0.6rem; padding: 0.5rem 0.65rem; background: #fff; border: 1px solid #c5d6e8; border-radius: 3px; font-size: 0.82em;">
      <div style="display: flex; flex-wrap: wrap; gap: 0.4rem 0.85rem; align-items: center;">
        <span><strong>site:</strong> <code class="mono" id="npd-summary-site">github</code></span>
        <span><strong>contentKind:</strong> <code class="mono" id="npd-summary-kind">tech-note</code></span>
        <span><strong>slug:</strong> <code class="mono" id="npd-summary-slug" style="color: #a00;">（未填 / 不合法）</code></span>
        <span><strong>filename:</strong> <code class="mono" id="npd-summary-filename" style="color: #a00;">（待 date + slug）</code></span>
        <span><strong>status:</strong> <span class="badge b-draft" style="font-size: 0.78em;">draft</span></span>
        <span><strong>ready:</strong> <span id="npd-summary-ready" class="badge b-draft" style="font-size: 0.78em;" aria-live="polite">missing title / slug / date</span></span>
