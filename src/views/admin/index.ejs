            <div id="npd-slug-suggestion" aria-live="polite"
                 style="display: none; margin-top: 0.3rem; padding: 0.35rem 0.5rem; background: #f4f7fb; border: 1px dashed #c5d6e8; border-radius: 3px; font-size: 0.8em;">
