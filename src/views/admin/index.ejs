              <span class="badge <%= p.completeness.seo === 'ok' ? 'b-ok' : 'b-missing' %>">SEO <%= p.completeness.seo %></span>
              <span class="badge <%= p.completeness.fb === 'ok' ? 'b-ok' : 'b-missing' %>">FB <%= p.completeness.fb %></span>
