  <%# === GA4 / Analytics（read-only，masked） === -%>
  <section class="admin-section" aria-labelledby="ga4-h">
    <h2 id="ga4">GA4 / Analytics <% if (sys && sys.ga4 && sys.ga4.enabled) { %><span class="section-tag tag-live">enabled</span><% } else { %><span class="section-tag tag-dormant">disabled</span><% } %> <span class="section-tag tag-readonly">read-only</span></h2>
    <p class="section-lede">measurementId 以 tail4 遮罩顯示；ADMIN 不打 GA4 API、不抓報表、不顯示真實流量。GA4 P1 article bottom nav 已驗證（20260615）。</p>
    <% if (sys && sys.ga4) { %>
    <div class="surface-grid">
      <div class="surface-card">
        <h3>主開關</h3>
        <dl>
          <dt>ga4.enabled</dt><dd><%= sys.ga4.enabled ? 'true' : 'false' %></dd>
          <dt>measurementId</dt><dd class="mono"><% if (sys.ga4.hasMeasurementId) { %>G-…<%= sys.ga4.measurementIdTail4 %><% } else { %><span class="empty">(none)</span><% } %></dd>
          <dt>events 註冊</dt><dd><%= sys.ga4.eventsCount %> 個</dd>
        </dl>
      </div>
