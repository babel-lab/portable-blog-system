                      title="複製建議 slug（不會覆蓋現有 slug 欄位）">Copy suggested slug</button>
              <span id="npd-slug-suggest-status" style="margin-left: 0.4rem; font-size: 0.82em;" aria-live="polite"></span>
            </div>
          </td>
        </tr>
