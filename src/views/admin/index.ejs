              %>
                <span class="validator-badge <%= v.ok ? 'ok' : 'error' %>" title="server-side pre-compute；per docs/20260527-admin-write-phase-3-dry-run-ui-preanalysis.md §6.1"><%= fname %>: <%= v.ok ? 'ok' : v.error %></span>
