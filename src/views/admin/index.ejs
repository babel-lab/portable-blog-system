                  <tr><td class="mono">postedAt</td><td class="fb-dry-run-old-value" data-fb-field="postedAt" data-current="<%= p.fbPostedAt %>"><%= p.fbPostedAt || '(empty)' %></td><td><input type="text" data-fb-input="postedAt" value="<%= p.fbPostedAt %>" placeholder="ISO 8601 或 YYYY-MM-DD HH:mm" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">postId</td><td class="fb-dry-run-old-value" data-fb-field="postId" data-current="<%= p.fbPostId %>"><%= p.fbPostId || '(empty)' %></td><td><input type="text" data-fb-input="postId" value="<%= p.fbPostId %>" placeholder="optional (Graph API)" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">campaign</td><td class="fb-dry-run-old-value" data-fb-field="campaign" data-current="<%= p.fbCampaign %>"><%= p.fbCampaign || '(empty)' %></td><td><input type="text" data-fb-input="campaign" value="<%= p.fbCampaign %>" placeholder="人工分類標記" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">audience</td><td class="fb-dry-run-old-value" data-fb-field="audience" data-current="<%= p.fbAudience %>"><%= p.fbAudience || '(empty)' %></td><td><input type="text" data-fb-input="audience" value="<%= p.fbAudience %>" placeholder="developers / parents / educators / ..." style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">title</td><td class="fb-dry-run-old-value" data-fb-field="title" data-current="<%= p.fbTitle %>"><%= p.fbTitle || '(empty)' %></td><td><input type="text" data-fb-input="title" value="<%= p.fbTitle %>" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">titleEn</td><td class="fb-dry-run-old-value" data-fb-field="titleEn" data-current="<%= p.fbTitleEn %>"><%= p.fbTitleEn || '(empty)' %></td><td><input type="text" data-fb-input="titleEn" value="<%= p.fbTitleEn %>" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">hashtags<br><small style="color: #777; font-size: 0.85em;">(一行一個)</small></td><td class="fb-dry-run-old-value" data-fb-field="hashtags" data-current="<%= Array.isArray(p.fbHashtags) ? p.fbHashtags.join('\n') : '' %>" style="white-space: pre-wrap;"><% if (Array.isArray(p.fbHashtags) && p.fbHashtags.length > 0) { %><%= p.fbHashtags.join('\n') %><% } else { %>(empty)<% } %></td><td><textarea data-fb-input="hashtags" rows="3" placeholder="一行一個 hashtag" style="width: 100%; padding: 0.25rem; font-family: inherit; resize: vertical;"><%= Array.isArray(p.fbHashtags) ? p.fbHashtags.join('\n') : '' %></textarea></td></tr>
                  <tr><td class="mono">imageUrl</td><td class="fb-dry-run-old-value" data-fb-field="imageUrl" data-current="<%= p.fbImageUrl %>"><%= p.fbImageUrl || '(empty)' %></td><td><input type="text" data-fb-input="imageUrl" value="<%= p.fbImageUrl %>" placeholder="https://... (外連；不直接載入)" style="width: 100%; padding: 0.25rem;"></td></tr>
                  <tr><td class="mono">note</td><td class="fb-dry-run-old-value" data-fb-field="note" data-current="<%= p.fbNote %>"><%= p.fbNote || '(empty)' %></td><td><textarea data-fb-input="note" rows="2" style="width: 100%; padding: 0.25rem; font-family: inherit; resize: vertical;"><%= p.fbNote %></textarea></td></tr>
                </tbody>
