              <button type="button" class="fb-dry-run-compute" style="padding: 0.35rem 0.75rem; border: 1px solid #2c5282; background: #cfe2ff; border-radius: 3px; cursor: pointer; font-size: 0.85em; font-weight: 600; color: #2c5282; margin-top: 0.5rem;">Show FB Dry-run Diff</button>
