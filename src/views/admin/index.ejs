  <%# Phase 20260523-pm-10-admin-empty-filter-state-a: fallback message when search / filter yields 0 matched rows
      （per docs/admin-overview-audit-20260523.md §10.1 A7）；matchedCount === 0 且 isFilterActive 時由 applyFilters()
      觸發顯示；初始 posts.length === 0 之 empty state 由 line 143 EJS 條件 render，與此 fallback 為兩個獨立情境。 -%>
  <div id="admin-empty-filter-state" class="empty" hidden>
    沒有符合目前搜尋 / 篩選條件的文章。請調整關鍵字或篩選條件。
  </div>
  <% } %>

  <div class="admin-meta" style="margin-top: 1rem;">
    <strong>說明：</strong>點任一 row 可展開 detail panel；再點一次收合。<br>
    <strong>搜尋：</strong>match title / titleEn / slug / category / id / tags（case-insensitive）。<br>
    <strong>邊界：</strong>本頁屬 read-only；無 form / 無 button writes；不會寫入任何 source 檔案。<br>
    <strong>規格：</strong>詳見 <code>docs/admin-1-readonly-preflight.md</code> / <code>docs/admin-mvp-pre-analysis.md</code>。
  </div>

  <%# Phase 20260615-night-1-admin-ia-shell-implementation-a：以下為 IA shell 新增之 read-only 區塊
      - 全部 read-only；沒有任何 Apply / Save / Submit / Edit / Delete / Publish 互動
      - 未實作項目以 "planned" 文字 + 灰色清單呈現；不放假按鈕引導誤點 -%>

  <%# === Categories & Tags（read-only） === -%>
  <%# Phase 20260615-night-5 / night-7-admin-tags-readonly-usage-counts-a
        - 從 sys.categories / sys.tags（registry shape）+ categoryUsage / tagUsage（per-post usage derive）四個來源組合
        - 全部 read-only；無 Add / Edit / Delete / Apply 互動
        - Categories 顯示：per-category postCount / status breakdown / source-site breakdown / cross-site mismatch / sample posts；
                           uncategorized / unknown / unused 三個 sub-bucket
        - Tags 顯示：per-tag postCount / status breakdown / source-site breakdown / cross-site mismatch / sample posts；
                     untagged / unknown / unused 三個 sub-bucket（per-tag 與 per-category 共用 CSS class，不引入新 token）
        - 明確標示資料來源 = posts (admin loader) + categories.json + tags.json
        - 不取代 validate-content 之 unknown-category / category-site-mismatch / unknown-tag / tag-site-mismatch warnings；
          admin 只摘要使用狀態，validator 仍為 ground truth -%>
  <%
    var catUsage = (typeof categoryUsage === 'object' && categoryUsage) ? categoryUsage : null;
    var catPer = (catUsage && Array.isArray(catUsage.perCategory)) ? catUsage.perCategory : [];
    var catUnused = (catUsage && Array.isArray(catUsage.unusedCategories)) ? catUsage.unusedCategories : [];
    var catUnknown = (catUsage && Array.isArray(catUsage.unknownCategories)) ? catUsage.unknownCategories : [];
    var catUncat = (catUsage && catUsage.uncategorized) ? catUsage.uncategorized : { count: 0, samplePosts: [], truncated: false };
    var catTotals = (catUsage && catUsage.totals) ? catUsage.totals : null;
    var catMismatchCategoryCount = catPer.filter(function(e) { return e.crossSiteMismatchCount > 0; }).length;
    // Phase 20260615-night-7-admin-tags-readonly-usage-counts-a
    var tagUsageLocal = (typeof tagUsage === 'object' && tagUsage) ? tagUsage : null;
    var tagPer = (tagUsageLocal && Array.isArray(tagUsageLocal.perTag)) ? tagUsageLocal.perTag : [];
    var tagUnused = (tagUsageLocal && Array.isArray(tagUsageLocal.unusedTags)) ? tagUsageLocal.unusedTags : [];
    var tagUnknown = (tagUsageLocal && Array.isArray(tagUsageLocal.unknownTags)) ? tagUsageLocal.unknownTags : [];
    var tagUntag = (tagUsageLocal && tagUsageLocal.untagged) ? tagUsageLocal.untagged : { count: 0, samplePosts: [], truncated: false };
    var tagTotals = (tagUsageLocal && tagUsageLocal.totals) ? tagUsageLocal.totals : null;
    var tagMismatchTagCount = tagPer.filter(function(e) { return e.crossSiteMismatchCount > 0; }).length;
    // Phase 20260616-am-4-admin-governance-summary-card-implementation-a：
    //   - view 端 reduce over posts[].governanceSignals（loader am-5 已 derive 五欄位）
    //   - 不改 loader / 不新增 summary object；沿用既有 posts.forEach 聚合慣例（L251 / L306 / L1442 / L1450）
    //   - 主軸 net-new rollup：govPostsWithSignals / govSignalTotal（任何既有 totals 皆無此統一 per-post rollup）
    //   - post-level cross-site mismatch：補既有 catMismatchCategoryCount / tagMismatchTagCount（key-level）之 post-level 視角
    //   - unknown tag/category posts：與 tagUsage.totals.postWithUnknownTagCount / categoryUsage.totals.unknownCategoryPosts 同源（文案標明）
    var govPostsTotal = Array.isArray(posts) ? posts.length : 0;
    var govPostsWithSignals = 0;
    var govSignalTotal = 0;
    var govPostsUnknownTag = 0;
    var govPostsUnknownCategory = 0;
    var govPostsMismatchTag = 0;
    var govPostsMismatchCategory = 0;
    if (Array.isArray(posts)) {
      posts.forEach(function(p) {
        var g = (p && p.governanceSignals) ? p.governanceSignals : {};
        var sum = g.signalSum || 0;
        if (sum > 0) govPostsWithSignals++;
        govSignalTotal += sum;
        if ((g.unknownTagCount || 0) > 0) govPostsUnknownTag++;
        if (g.unknownCategoryFlag === true) govPostsUnknownCategory++;
        if ((g.crossSiteMismatchTagCount || 0) > 0) govPostsMismatchTag++;
        if (g.crossSiteMismatchCategoryFlag === true) govPostsMismatchCategory++;
      });
    }
  %>
  <section class="admin-section" aria-labelledby="categories-h">
    <h2 id="categories">Categories &amp; Tags <span class="section-tag tag-readonly">read-only</span></h2>
    <p class="section-lede">
      資料來源 = <code>content/settings/categories.json</code> / <code>content/settings/tags.json</code>（registry）+ admin loader 掃 <code>content/{github,blogger}/posts/*.md</code> 之 <code>frontmatter.category</code> / <code>frontmatter.tags</code> 反向統計。
      下表為「目前各分類 / 標籤被多少文章使用」之 read-only 摘要；不取代 <code>npm run validate:content</code> 之 <code>unknown-category</code> / <code>category-site-mismatch</code> / <code>unknown-tag</code> / <code>tag-site-mismatch</code> 警示（validator 仍為 ground truth）。
      本區無 Add / Edit / Delete / Save / Apply 按鈕；增刪分類 / 標籤請手改 <code>categories.json</code> / <code>tags.json</code> + <code>npm run validate:content</code>。
    </p>

    <%# Phase 20260616-am-3-admin-suggested-fix-readonly-ui-docs-cross-link-implementation-a：
        - read-only governance docs cross-link callout（切片 1：最低風險）
        - 明示治理訊號 read-only；不自動修改文章 / registry / 不自動套用任何修正
        - 列出兩份治理 docs 路徑 + dev-time 相對 href（/admin/ → ../docs/）
        - 不引入 form / button / input / select / textarea / fetch
        - 不含 per-post prescription（「應改為 X」）字樣 -%>
    <aside class="admin-governance-note" aria-label="governance docs cross-link" style="margin: 0.5rem 0 0.75rem; padding: 0.55rem 0.8rem; background: #f4f7fb; border-left: 3px solid #6c7a89; border-radius: 4px; font-size: 0.86em; line-height: 1.55;">
      <p style="margin: 0;">
        <strong>讀法說明：</strong>下列各區（per-category / per-tag usage、uncategorized / unknown / unused / untagged sub-buckets、cross-site mismatch）皆為治理訊號，<strong>read-only</strong>。Admin 不會自動修改文章 frontmatter、不會自動修改 <code>categories.json</code> / <code>tags.json</code>、不會自動套用任何修正。請先閱讀治理文件，再由人眼決定是否另開修正 phase。
      </p>
      <p style="margin: 0.3rem 0 0;">
        <strong>治理文件：</strong>
        <a href="../docs/20260615-admin-content-taxonomy-governance-preanalysis.md" rel="noopener"><code>docs/20260615-admin-content-taxonomy-governance-preanalysis.md</code></a>
        （taxonomy 治理規則、五維度分析、decision options、status / surface 分級）·
        <a href="../docs/20260616-admin-suggested-fix-readonly-ui-preanalysis.md" rel="noopener"><code>docs/20260616-admin-suggested-fix-readonly-ui-preanalysis.md</code></a>
        （本區 suggested-fix UI 顯示哲學、L1–L4 分級、UI contract 紅線）
      </p>
    </aside>

    <%# Phase 20260616-am-4-admin-governance-summary-card-implementation-a：
        - read-only governance summary card（Option B：Categories & Tags section 前方）
        - 資料 = view 端 reduce over posts[].governanceSignals（不改 loader / 不新增 summary object）
        - 主軸 = 統一 per-post rollup（posts with signals / total signal count）= net-new（既有 totals 皆無）
        - 含 post-level cross-site mismatch（補 key-level catMismatchCategoryCount / tagMismatchTagCount 之新視角）
        - unknown tag / unknown category posts：與下方 key-level totals 同源 → 文案標明，不誤導為新問題
        - read-only only：無 form / button / input / select / textarea / fetch / onclick；無 per-post prescription；
          warn 一級不暗示 build blocker；healthy empty-state 不過度承諾
        - 沿用既有 .surface-card / .cat-totals-row / .totals-pill(.warn) class（零新 CSS） -%>
    <div class="surface-card" aria-label="governance summary" style="margin: 0 0 0.85rem; background: #fbfdff;">
      <h3>🏷️ 內容治理摘要 / Governance summary <span class="section-tag tag-readonly" style="font-size: 0.7em;">read-only · derived</span></h3>
      <p class="surface-note" style="margin: 0 0 0.5rem;">
        全站 <strong>per-post</strong> 治理訊號 rollup（彙整自各文章之 <code>governanceSignals</code>，含 draft / 全 status）。
        此為「<strong>有幾篇文章</strong>帶治理訊號」之 post-level 視角；下方各區之 totals 為 per-category / per-tag 之 <strong>key-level</strong> 統計，兩者維度不同、彼此互補。
        本卡為 read-only 摘要，<strong>逐篇明細仍以 Posts index 之 gov badge 與 detail panel 之 Governance signals section 為準</strong>。
      </p>
      <div class="cat-totals-row" aria-label="governance summary totals">
        <span class="totals-pill"><strong><%= govPostsTotal %></strong> 篇文章檢視（含 draft）</span>
        <% if (govPostsWithSignals > 0) { %>
          <span class="totals-pill warn"><strong><%= govPostsWithSignals %></strong> 篇有治理訊號</span>
          <span class="totals-pill warn"><strong><%= govSignalTotal %></strong> 治理訊號總數</span>
        <% } else { %>
          <span class="totals-pill"><strong>0</strong> 篇有治理訊號</span>
          <span class="totals-pill"><strong>0</strong> 治理訊號總數</span>
        <% } %>
        <% if (govPostsMismatchTag > 0) { %>
          <span class="totals-pill warn"><strong><%= govPostsMismatchTag %></strong> 篇 cross-site mismatch · tag</span>
        <% } else { %>
          <span class="totals-pill"><strong>0</strong> 篇 cross-site mismatch · tag</span>
        <% } %>
        <% if (govPostsMismatchCategory > 0) { %>
          <span class="totals-pill warn"><strong><%= govPostsMismatchCategory %></strong> 篇 cross-site mismatch · category</span>
        <% } else { %>
          <span class="totals-pill"><strong>0</strong> 篇 cross-site mismatch · category</span>
        <% } %>
      </div>
      <p class="surface-note" style="margin: 0.4rem 0 0;">
        <% if (govPostsUnknownTag > 0 || govPostsUnknownCategory > 0) { %>
          其中 <strong><%= govPostsUnknownTag %></strong> 篇含 unknown tag、<strong><%= govPostsUnknownCategory %></strong> 篇 unknown category
          （此兩項與下方 per-tag / per-category 區之 <code>postWithUnknownTagCount</code> / <code>unknown category</code> totals <strong>同源</strong>，僅維度視角不同，非另一組新問題）。
        <% } else { %>
          ✓ 目前 admin 資料集（含 draft）未偵測到 unknown tag / unknown category / cross-site mismatch 治理訊號。此僅反映現況快照，不代表全站永久正確。
        <% } %>
      </p>
      <p class="surface-note" style="margin: 0.4rem 0 0; color: #6c7a89;">
        治理訊號為 <strong>read-only 人眼提示</strong>，<strong>非 build blocker</strong>（<code>npm run validate:content</code> 對 production 仍 0 error）；Admin 不會自動修改文章 frontmatter / <code>categories.json</code> / <code>tags.json</code>。是否調整由人眼判斷後另開 phase；validator 仍為 ground truth。
      </p>
    </div>

    <div class="surface-grid">
      <div class="surface-card">
        <h3>Categories registry</h3>
        <dl>
          <dt>定義數</dt><dd><%= sys && sys.categories ? sys.categories.total : 0 %></dd>
          <dt>github surface</dt><dd><%= sys && sys.categories ? sys.categories.bySite.github : 0 %></dd>
          <dt>blogger surface</dt><dd><%= sys && sys.categories ? sys.categories.bySite.blogger : 0 %></dd>
        </dl>
      </div>
      <div class="surface-card">
        <h3>Tags registry</h3>
        <dl>
          <dt>定義數</dt><dd><%= sys && sys.tags ? sys.tags.total : 0 %></dd>
          <dt>github surface</dt><dd><%= sys && sys.tags ? sys.tags.bySite.github : 0 %></dd>
          <dt>blogger surface</dt><dd><%= sys && sys.tags ? sys.tags.bySite.blogger : 0 %></dd>
        </dl>
        <p class="surface-note">用量計數 / 未使用偵測 / cross-site mismatch 見下方 Per-tag usage（本區無編輯 UI）。</p>
      </div>
    </div>

    <%# Phase 20260617-night-admin-categories-tags-collapsible-split-implementation-a:
        presentation-only — Categories 用量群包進原生 <details>（預設 open，資訊不被藏，使用者可手動收合縮短 section）。
        零 data / loader / validator / report 變更；summary 僅複述既有子標題語意，不引入新資料判斷。 -%>
    <details open class="cat-tags-group" style="margin: 0.5rem 0 0;">
      <summary style="cursor: pointer; font-weight: 600; color: #1f2d3d;">Categories 用量明細 — per-category usage · uncategorized · unknown category · unused（read-only）</summary>
    <% if (catTotals) { %>
    <div class="cat-totals-row" aria-label="categories totals">
      <span class="totals-pill"><strong><%= catTotals.totalPosts %></strong> 篇文章（含 draft）</span>
      <span class="totals-pill"><strong><%= catTotals.categorizedPosts %></strong> 已分類</span>
      <% if (catTotals.uncategorizedPosts > 0) { %>
        <span class="totals-pill warn"><strong><%= catTotals.uncategorizedPosts %></strong> uncategorized</span>
      <% } else { %>
        <span class="totals-pill"><strong>0</strong> uncategorized</span>
      <% } %>
      <% if (catTotals.unknownCategoryPosts > 0) { %>
        <span class="totals-pill warn"><strong><%= catTotals.unknownCategoryPosts %></strong> unknown category</span>
      <% } else { %>
        <span class="totals-pill"><strong>0</strong> unknown category</span>
      <% } %>
      <% if (catTotals.unusedCategoryCount > 0) { %>
        <span class="totals-pill warn"><strong><%= catTotals.unusedCategoryCount %></strong> unused defined</span>
      <% } else { %>
        <span class="totals-pill"><strong>0</strong> unused defined</span>
      <% } %>
      <% if (catMismatchCategoryCount > 0) { %>
        <span class="totals-pill warn"><strong><%= catMismatchCategoryCount %></strong> cross-site mismatch</span>
      <% } else { %>
        <span class="totals-pill"><strong>0</strong> cross-site mismatch</span>
      <% } %>
    </div>
    <% } %>

    <h3 style="margin: 0.75rem 0 0.25rem; font-size: 0.95em; color: #1f2d3d;">Per-category usage</h3>
    <% if (catPer.length === 0) { %>
      <p class="empty">categories.json 未定義任何 category。</p>
    <% } else { %>
    <table class="cat-usage-table" aria-label="per category usage table">
      <thead>
        <tr>
          <th style="width: 9rem;">id / slug</th>
          <th style="width: 10rem;">name</th>
          <th style="width: 9rem;">allowed sites</th>
          <th style="width: 5.5rem; text-align: right;">posts</th>
          <th>status breakdown</th>
          <th style="width: 9rem;">by source site</th>
          <th>sample posts</th>
        </tr>
      </thead>
      <tbody>
        <% catPer.forEach(function(c) { %>
          <% var total = c.postCount; var sb = c.statusBreakdown; %>
          <tr class="<%= total === 0 ? 'is-zero' : '' %>">
            <td>
              <div><code class="cat-id"><%= c.id %></code></div>
              <% if (c.slug && c.slug !== c.id) { %><div class="text-muted" style="font-size: 0.82em;">slug: <code class="cat-id"><%= c.slug %></code></div><% } %>
            </td>
            <td><span class="cat-name"><%= c.name || '(no name)' %></span></td>
            <td class="cat-site">
              <% if (Array.isArray(c.site) && c.site.length > 0) { %>
                <% c.site.forEach(function(s) { %><span class="badge b-info"><%= s %></span><% }); %>
              <% } else { %>
                <span class="text-muted">—</span>
              <% } %>
            </td>
            <td style="text-align: right; font-weight: 700; color: <%= total === 0 ? '#999' : '#2c5282' %>;">
              <%= total %>
            </td>
            <td>
              <% if (total === 0) { %>
                <span class="text-muted">—</span>
              <% } else { %>
