      // Phase 20260629-admin-tag-picker-site-aware-options-a:
      //   Site-aware tag datalist. Rebuild #npd-tags-options from the injected
      //   registry snapshot whenever #npd-site changes so the autocomplete only
      //   suggests tags valid for the selected site (site=github → github / vite
      //   / static-site; never Blogger-only tags like reading-notes). Mirrors the
      //   server-side default-github datalist filter above. Free text is always
      //   allowed — #npd-tags stays type=text; this is hint-only, not a select.
      var TAGS_DATALIST_EL = document.getElementById('npd-tags-options');
      function escAttr(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;')
          .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }
      function renderTagOptions(site) {
        if (!TAGS_DATALIST_EL) return;
        var picked = VALID_SITES.indexOf(site) >= 0 ? site : 'github';
        var regTags = Array.isArray(REGISTRY_SNAPSHOT.tags) ? REGISTRY_SNAPSHOT.tags : [];
        var html = '';
        for (var i = 0; i < regTags.length; i++) {
          var t = regTags[i] || {};
          var tid = (typeof t.id === 'string' && t.id) ? t.id : (typeof t.slug === 'string' ? t.slug : '');
          if (tid === '') continue;
          var sites = Array.isArray(t.site) ? t.site : [];
          if (sites.length > 0 && sites.indexOf(picked) < 0) continue;
          var label = sites.length ? (tid + ' [' + sites.join('/') + ']') : tid;
          html += '<option value="' + escAttr(tid) + '" label="' + escAttr(label) + '"></option>';
        }
        TAGS_DATALIST_EL.innerHTML = html;
      }
      SITE_EL.addEventListener('change', function () { renderTagOptions(SITE_EL.value); });
      renderTagOptions(SITE_EL.value);

      // Phase 20260701-admin-primary-platform-auto-follow-site-a:
      //   primaryPlatform auto-follows #npd-site. Before this, #npd-primary kept
      //   its independent default (github) when Dean switched #npd-site to
      //   blogger, so a fresh blogger draft silently exported
      //   primaryPlatform: github — a site !== primaryPlatform mismatch that only
      //   surfaced later in the .md. syncPrimaryToSite(site) sets #npd-primary to
      //   the same github|blogger value on every site change; #npd-primary stays
      //   a manual <select> afterwards (its own change listener via the
      //   [SITE_EL, KIND_EL, PRIM_EL, CAT_EL] recompute wiring above still fires),
      //   so this only removes the stale default, not the deliberate override.
      //   Registered before the category change handler so the follow lands
      //   before that handler's trailing recompute() reads PRIM_EL.value. No new
      //   write path / fetch / fs — a value assignment on an existing <select>.
      function syncPrimaryToSite(site) {
        if (!PRIM_EL) return;
        PRIM_EL.value = VALID_SITES.indexOf(site) >= 0 ? site : 'github';
      }
      SITE_EL.addEventListener('change', function () { syncPrimaryToSite(SITE_EL.value); });
      syncPrimaryToSite(SITE_EL.value);

      // Phase 20260701-admin-category-select-site-aware-options-a:
      //   Site-aware category <select>. Mirror of the server default-github
      //   option filter + the renderTagOptions pattern: rebuild #npd-category
      //   options from REGISTRY_SNAPSHOT.categories whenever #npd-site changes,
      //   preserving a still-valid selection or falling back to the first
      //   available category for the new site (an invalid / cross-site value
      //   resets rather than lingering as a category-site-mismatch). Stays a
      //   registry-bound <select> — CAT_EL.innerHTML holds <option>s only, no
      //   free-text input, per smoke #156-157. recompute() runs right after the
      //   rebuild so the markdown preview + Ready preflight reflect the (possibly
      //   reset) category on the same tick as the site switch.
      function renderCategoryOptions(site) {
        if (!CAT_EL) return;
        var picked = VALID_SITES.indexOf(site) >= 0 ? site : 'github';
        var regCats = Array.isArray(REGISTRY_SNAPSHOT.categories) ? REGISTRY_SNAPSHOT.categories : [];
        var prev = CAT_EL.value;
        var available = [];
        for (var i = 0; i < regCats.length; i++) {
          var c = regCats[i] || {};
          var cid = (typeof c.id === 'string' && c.id) ? c.id : (typeof c.slug === 'string' ? c.slug : '');
          if (cid === '') continue;
          var sites = Array.isArray(c.site) ? c.site : [];
          if (sites.length > 0 && sites.indexOf(picked) < 0) continue;
          var cname = (typeof c.name === 'string' && c.name) ? c.name : cid;
          available.push({ id: cid, name: cname, sites: sites });
        }
        var out = '';
        for (var j = 0; j < available.length; j++) {
          var a = available[j];
          var label = a.sites.length
            ? (a.id + ' — ' + a.name + ' [' + a.sites.join('/') + ']')
            : (a.id + ' — ' + a.name);
          out += '<option value="' + escAttr(a.id) + '">' + escAttr(label) + '</option>';
        }
        CAT_EL.innerHTML = out;
        var stillValid = false;
        for (var k = 0; k < available.length; k++) {
          if (available[k].id === prev) { stillValid = true; break; }
        }
        CAT_EL.value = stillValid ? prev : (available.length ? available[0].id : '');
      }
      SITE_EL.addEventListener('change', function () { renderCategoryOptions(SITE_EL.value); recompute(); });
      renderCategoryOptions(SITE_EL.value);

      // Phase 20260701-admin-site-registry-reference-display-slice-b:
      //   Read-only reference block: rebuild #npd-site-registry-ref to list the
      //   categories / tags valid for the selected site. DISPLAY-ONLY — reuses the
      //   injected REGISTRY_SNAPSHOT (no new fetch / registry source), writes only
      //   its own innerHTML, and never touches CAT_EL / the tags datalist / PRIM_EL
      //   / recompute(). Additive SITE_EL listener registered after the site-aware
      //   filtering + primaryPlatform-follow handlers, so their order / recompute
      //   timing is unchanged. Mirrors the server-side initial paint (default github).
      var SITE_REGISTRY_REF_EL = document.getElementById('npd-site-registry-ref');
      function renderSiteRegistryReference(site) {
        if (!SITE_REGISTRY_REF_EL) return;
        var picked = VALID_SITES.indexOf(site) >= 0 ? site : 'github';
        var regCats = Array.isArray(REGISTRY_SNAPSHOT.categories) ? REGISTRY_SNAPSHOT.categories : [];
        var regTags = Array.isArray(REGISTRY_SNAPSHOT.tags) ? REGISTRY_SNAPSHOT.tags : [];
        var catParts = [];
        for (var i = 0; i < regCats.length; i++) {
          var c = regCats[i] || {};
          var cid = (typeof c.id === 'string' && c.id) ? c.id : (typeof c.slug === 'string' ? c.slug : '');
          if (cid === '') continue;
          var csite = Array.isArray(c.site) ? c.site : [];
          if (csite.length > 0 && csite.indexOf(picked) < 0) continue;
          var cname = (typeof c.name === 'string' && c.name) ? c.name : cid;
          catParts.push(csite.length ? (cid + ' — ' + cname + ' [' + csite.join('/') + ']') : (cid + ' — ' + cname));
        }
        var tagParts = [];
        for (var j = 0; j < regTags.length; j++) {
          var t = regTags[j] || {};
          var tid = (typeof t.id === 'string' && t.id) ? t.id : (typeof t.slug === 'string' ? t.slug : '');
          if (tid === '') continue;
          var tsite = Array.isArray(t.site) ? t.site : [];
          if (tsite.length > 0 && tsite.indexOf(picked) < 0) continue;
          tagParts.push(tsite.length ? (tid + ' [' + tsite.join('/') + ']') : tid);
        }
        var catText = catParts.length ? catParts.join('、') : '（此 site 無合法 category）';
        var tagText = tagParts.length ? tagParts.join('、') : '（此 site 無合法 tag）';
        SITE_REGISTRY_REF_EL.innerHTML =
          '<div style="margin-bottom: 0.25rem;"><strong>categories：</strong>' + escAttr(catText) + '</div>' +
          '<div><strong>tags：</strong>' + escAttr(tagText) + '</div>';
      }
      SITE_EL.addEventListener('change', function () { renderSiteRegistryReference(SITE_EL.value); });
      renderSiteRegistryReference(SITE_EL.value);

      // Phase 20260701-admin-tag-registry-inline-hint-slice-c1:
      //   Inline mirror of the tags-only subset of analyzeRegistryHints() into
      //   #npd-tags-registry-hint below the tags input. Reuses the reg object
      //   already computed by recompute() (no double compute; no new registry
      //   source). Read-only display: never mutates buildMarkdown output
      //   (status stays draft), never touches #npd-ready-registry-hints (Ready
      //   preflight aggregate stays intact — no dedupe), never touches the tags
      //   datalist / CAT_EL / PRIM_EL. Empty tags → hidden (no layout jump).
      //   No READY / PASS wording — describes registry alignment only. Site /
      //   tags-input listeners are the pre-existing recompute() wiring
      //   (SITE_EL 'change' + TAGS_EL 'input' → debounceRecompute); no new
      //   listener registered here.
      var TAGS_HINT_EL = document.getElementById('npd-tags-registry-hint');
      function renderTagsRegistryHint(rh, input) {
        if (!TAGS_HINT_EL) return;
        var safeInput = input && typeof input === 'object' ? input : {};
        var tagsList = normalizeTags(safeInput.tags);
        if (tagsList.length === 0) {
          TAGS_HINT_EL.style.display = 'none';
          TAGS_HINT_EL.textContent = '';
          return;
        }
        var regTags = Array.isArray(REGISTRY_SNAPSHOT.tags) ? REGISTRY_SNAPSHOT.tags : [];
        if (regTags.length === 0) {
          TAGS_HINT_EL.style.display = '';
          TAGS_HINT_EL.style.color = '#666';
          TAGS_HINT_EL.textContent = '（registry 為空，跳過對齊檢查）';
          return;
        }
        var hints = (rh && Array.isArray(rh.hints)) ? rh.hints : [];
        var unknown = [];
        var mismatch = [];
        for (var i = 0; i < hints.length; i++) {
          var h = hints[i];
          if (!h || h.field !== 'tags') continue;
          if (h.kind === 'unknown-tag') unknown.push(h);
          else if (h.kind === 'tag-site-mismatch') mismatch.push(h);
        }
        if (unknown.length === 0 && mismatch.length === 0) {
          TAGS_HINT_EL.style.display = '';
          TAGS_HINT_EL.style.color = '#155724';
          TAGS_HINT_EL.textContent = '✓ ' + tagsList.length + ' 個 tag 皆在 tags.json 且符合目前 site';
          return;
        }
        var parts = [];
        if (unknown.length > 0) {
          parts.push('未在 tags.json：' + unknown.map(function (h) { return h.value; }).join('、'));
        }
        for (var m = 0; m < mismatch.length; m++) {
          var hm = mismatch[m];
          var allowed = Array.isArray(hm.siteAllowed) ? hm.siteAllowed.join(',') : '';
          parts.push('site mismatch：' + hm.value + '（允許 site=[' + allowed + ']，目前 site=' + hm.siteCurrent + '）');
        }
        TAGS_HINT_EL.style.display = '';
        TAGS_HINT_EL.style.color = '#1f4e79';
        TAGS_HINT_EL.textContent = '⚠ ' + parts.join('；');
      }

      // Phase 20260701-admin-slug-suggestion-helper-slice-a:
      //   Client mirror of admin-markdown-export.js suggestSlugFromTitle +
      //   slugifyForSuggestion. Pure functions; no DOM read/write inside these
      //   two helpers themselves — only the renderSlugSuggestion() below binds
      //   the result to the slug-suggestion strip.
      var SLUG_SUGGEST_MAX_LEN = 80;
      function slugifyForSuggestion(raw) {
        var stripped = String(raw == null ? '' : raw)
          .toLowerCase()
          .replace(/[^a-z0-9\s-]/g, ' ')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-')
          .replace(/^-+|-+$/g, '');
        if (stripped === '') return '';
        var capped = stripped;
        if (capped.length > SLUG_SUGGEST_MAX_LEN) {
          capped = capped.slice(0, SLUG_SUGGEST_MAX_LEN);
          var lastHyphen = capped.lastIndexOf('-');
          if (lastHyphen > 0) capped = capped.slice(0, lastHyphen);
          capped = capped.replace(/^-+|-+$/g, '');
        }
        if (capped === '') return '';
        if (!SLUG_RE.test(capped)) return '';
        return capped;
      }
      // Phase 20260702-admin-slug-suggestion-title-ascii-only-fallback-slice-a:
      //   Client mirror of admin-markdown-export.js containsNonAscii + updated
      //   suggestSlugFromTitle. Title fallback rejects any non-ASCII input to
      //   avoid extracting stray ASCII fragments from CJK-mixed titles.
      var SLUG_SUGGEST_NON_ASCII_RE = /[^\x00-\x7f]/;
      function containsNonAscii(raw) {
        return SLUG_SUGGEST_NON_ASCII_RE.test(String(raw == null ? '' : raw));
      }
      function suggestSlugFromTitle(input) {
        var safeInput = input && typeof input === 'object' ? input : {};
        var titleEnRaw = String(safeInput.titleEn == null ? '' : safeInput.titleEn);
        var titleRaw = String(safeInput.title == null ? '' : safeInput.title);
        var candidateEn = slugifyForSuggestion(titleEnRaw);
        if (candidateEn !== '') return { suggested: candidateEn, source: 'titleEn' };
        if (containsNonAscii(titleRaw)) return { suggested: '', source: 'none' };
        var candidate = slugifyForSuggestion(titleRaw);
        if (candidate !== '') return { suggested: candidate, source: 'title' };
        return { suggested: '', source: 'none' };
      }
      // Phase 20260701-admin-slug-suggestion-helper-slice-a:
      //   Local status sink for the Copy suggested slug button. Mirrors
      //   showFlowStatus / showGapStatus 2s-clear contract. DOM-text only.
      function showSlugSuggestStatus(msg, isErr) {
        if (!SLUG_SUGGEST_STATUS_EL) return;
        SLUG_SUGGEST_STATUS_EL.textContent = msg;
        SLUG_SUGGEST_STATUS_EL.style.color = isErr ? '#a00' : '#080';
        setTimeout(function () {
          if (SLUG_SUGGEST_STATUS_EL.textContent === msg) SLUG_SUGGEST_STATUS_EL.textContent = '';
        }, 2000);
      }
      // Phase 20260701-admin-slug-suggestion-helper-slice-a:
      //   renderSlugSuggestion — display-only. Writes at most to:
      //     - SLUG_SUGGEST_EL.style.display
      //     - SLUG_SUGGEST_TEXT_EL.textContent
      //     - COPY_SLUG_SUGGEST_BTN.disabled / aria-disabled / dataset.suggested
      //   NEVER touches SLUG_EL, OUT_EL, or any other form / summary / preflight
      //   surface. NEVER uses innerHTML. NEVER auto-fills the slug input.
      //   Four UI states:
      //     - title + titleEn 都空 → hide (no noise on empty form)
      //     - has suggestion, slug 欄位空 → 建議 slug：xxx
      //     - has suggestion, slug 欄位 === xxx → slug 已與建議相符：xxx
      //     - has suggestion, slug 欄位有其他值 → 建議 slug：xxx（不會覆蓋現有 slug）
      //     - 有輸入但無法產生建議（CJK / 符號 only）→ 顯示 titleEn 引導文案，Copy disabled
      function renderSlugSuggestion(input) {
        if (!SLUG_SUGGEST_EL || !SLUG_SUGGEST_TEXT_EL || !COPY_SLUG_SUGGEST_BTN) return;
        var safeInput = input && typeof input === 'object' ? input : {};
        var titleRaw = String(safeInput.title == null ? '' : safeInput.title).replace(/^\s+|\s+$/g, '');
        var titleEnRaw = String(safeInput.titleEn == null ? '' : safeInput.titleEn).replace(/^\s+|\s+$/g, '');
        var currentSlugRaw = String(safeInput.slug == null ? '' : safeInput.slug).replace(/^\s+|\s+$/g, '');
        // Empty form → hide.
        if (titleRaw === '' && titleEnRaw === '') {
          SLUG_SUGGEST_EL.style.display = 'none';
          SLUG_SUGGEST_TEXT_EL.textContent = '';
          COPY_SLUG_SUGGEST_BTN.disabled = true;
          COPY_SLUG_SUGGEST_BTN.setAttribute('aria-disabled', 'true');
          COPY_SLUG_SUGGEST_BTN.dataset.suggested = '';
          return;
        }
        var result = suggestSlugFromTitle({ title: titleRaw, titleEn: titleEnRaw });
        if (result.suggested === '') {
          // No slug producible (CJK-only / symbols-only) — show guidance, disable Copy.
          SLUG_SUGGEST_EL.style.display = '';
          SLUG_SUGGEST_TEXT_EL.style.color = '#1f4e79';
          SLUG_SUGGEST_TEXT_EL.textContent = '暫無 slug 建議：請在 titleEn 填英文短句，或手動輸入 kebab-case slug';
          COPY_SLUG_SUGGEST_BTN.disabled = true;
          COPY_SLUG_SUGGEST_BTN.setAttribute('aria-disabled', 'true');
          COPY_SLUG_SUGGEST_BTN.dataset.suggested = '';
          return;
        }
        SLUG_SUGGEST_EL.style.display = '';
        SLUG_SUGGEST_TEXT_EL.style.color = '#1f4e79';
        COPY_SLUG_SUGGEST_BTN.disabled = false;
        COPY_SLUG_SUGGEST_BTN.setAttribute('aria-disabled', 'false');
        COPY_SLUG_SUGGEST_BTN.dataset.suggested = result.suggested;
        if (currentSlugRaw === '') {
          SLUG_SUGGEST_TEXT_EL.textContent = '建議 slug：' + result.suggested + '（來源：' + result.source + '）';
        } else if (currentSlugRaw === result.suggested) {
          SLUG_SUGGEST_TEXT_EL.textContent = 'slug 已與建議相符：' + result.suggested;
        } else {
          SLUG_SUGGEST_TEXT_EL.textContent = '建議 slug：' + result.suggested + '（不會覆蓋現有 slug）';
        }
      }
      // Phase 20260701-admin-slug-suggestion-helper-slice-a:
      //   Copy suggested slug — clipboard-only. Reads dataset.suggested
      //   (populated by renderSlugSuggestion above) and calls the vetted
      //   copyTextToClipboard() helper. Never touches SLUG_EL / OUT_EL /
      //   markdown export path.
      if (COPY_SLUG_SUGGEST_BTN) {
        COPY_SLUG_SUGGEST_BTN.addEventListener('click', function () {
          if (COPY_SLUG_SUGGEST_BTN.disabled) return;
          var suggested = COPY_SLUG_SUGGEST_BTN.dataset.suggested || '';
          if (suggested === '') { showSlugSuggestStatus('尚無建議 slug', true); return; }
          copyTextToClipboard(suggested, '已複製建議 slug', showSlugSuggestStatus);
        });
      }

      recompute();
    })();
  </script>

  <%# Phase 20260617-night-admin-categories-tags-collapsible-split-implementation-a:
      最小、隔離之 client script —— 當 location.hash 指向某 <details> 內部元素（如 nav #tags 在使用者手動收合 Tags 群後），
      自動展開其祖先 <details>，確保錨點跳轉不會落入收合區而「找不到」。
      只讀 location.hash + 設定 details.open；不碰 filter / search / sort / detail-panel toggle 任何邏輯。 -%>
  <script>
    (function () {
      function openHashDetails() {
        var h = location.hash;
        if (!h || h.length < 2) return;
        var el;
        try { el = document.getElementById(decodeURIComponent(h.slice(1))); } catch (e) { return; }
        if (!el) return;
        var d = el.closest ? el.closest('details') : null;
        while (d) {
          d.open = true;
          d = (d.parentElement && d.parentElement.closest) ? d.parentElement.closest('details') : null;
        }
      }
      window.addEventListener('hashchange', openHashDetails);
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', openHashDetails);
      } else {
        openHashDetails();
      }
    })();
  </script>
</body>
</html>
