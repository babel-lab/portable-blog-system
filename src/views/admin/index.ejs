              <dt>fbPostUrl</dt><dd class="mono"><% if (p.fbPostUrl) { %><a href="<%= p.fbPostUrl %>" target="_blank" rel="noopener noreferrer"><%= p.fbPostUrl %> ↗</a><% } else { %>(empty)<% } %></dd>
              <dt>fbPostedAt</dt><dd class="mono"><%= p.fbPostedAt || '(empty)' %></dd>
