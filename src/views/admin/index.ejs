        <h3>publishTargets.blogger</h3>
        <dl>
          <dt>enabled posts</dt><dd><%= bloggerEnabledLocal %></dd>
          <dt>mode: full</dt><dd><%= bloggerByMode.full %></dd>
          <dt>mode: summary</dt><dd><%= bloggerByMode.summary %></dd>
          <dt>mode: redirect-card</dt><dd><%= bloggerByMode['redirect-card'] %></dd>
          <dt>有 publishedUrl</dt><dd><%= bloggerPublishedUrlCount %> / <%= bloggerEnabledLocal %></dd>
