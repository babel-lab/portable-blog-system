  <% if (posts.length > 0) { %>
  <script>
    (function () {
      // Phase 20260520-b-4 + 20260522-night-3-b: show-all toggle config
      // SHOW_LIMIT 為 Admin overview 之 default recent N；per night-3-b 由 20 提升至 30
      var SHOW_LIMIT = 30;
      var showAll = false;
      var search = document.getElementById('admin-search');
      var filter = document.getElementById('admin-filter');
      var visibleCount = document.getElementById('admin-visible-count');
      var showAllToggle = document.getElementById('admin-show-all-toggle');
      var sort = document.getElementById('admin-sort');
      // Phase 20260523-pm-10-admin-empty-filter-state-a: empty-filter-state element ref（per docs/admin-overview-audit-20260523.md §10.1 A7）
      var emptyFilterState = document.getElementById('admin-empty-filter-state');
      var rows = Array.prototype.slice.call(document.querySelectorAll('tr.post-row'));
      var details = Array.prototype.slice.call(document.querySelectorAll('tr.post-detail'));

      function matchesFilter(row, f) {
        if (f === 'all' || !f) return true;
        var parts = f.split(':');
        var key = parts[0];
        var val = parts[1];
        switch (key) {
          case 'status': return row.dataset.status === val;
          case 'blogger': return row.dataset.blogger === val;
          case 'github': return row.dataset.github === val;
          case 'kind': return row.dataset.contentKind === val;
          // Phase 20260522-night-3-c: category / series filter；對齊 row data-category / data-series；isFilterActive 自動觸發（per night-3-b 既有邏輯）
          case 'category': return row.dataset.category === val;
          case 'series': return row.dataset.series === val;
          // Phase 20260523-pm-3-admin-a1-source-site-filter-optgroup-a: sourceSite filter（per docs/admin-overview-audit-20260523.md §10.1 A1）；對齊 row data-source-site
          case 'sourceSite': return row.dataset.sourceSite === val;
          // Phase 20260523-pm-5-admin-a2-fb-badge-filter-optgroup-a: fbBadge filter（per docs/admin-overview-audit-20260523.md §10.1 A2）；對齊 row data-fb-badge；4 well-known values
          case 'fbBadge': return row.dataset.fbBadge === val;
          // Phase 20260617-am-admin-validator-state-filter-chip-list-implementation-a: validation filter（4 態 read-only）；對齊 row data-validation-state；純比對既有 derived 字串，無 rule 重算
          case 'validation': return row.dataset.validationState === val;
          case 'completeness':
            // val 形如 "seo-missing" / "fb-missing" / "url-missing" / "categoryTags-missing"
            if (val === 'seo-missing') return row.dataset.seo === 'missing';
            if (val === 'fb-missing') return row.dataset.fb === 'missing';
            if (val === 'url-missing') return row.dataset.url === 'missing';
            if (val === 'categoryTags-missing') return row.dataset.catTags === 'missing';
            if (val === 'fbPublished-missing') return row.dataset.fbPublished === 'missing';
            return true;
          default: return true;
        }
      }

      // Phase 20260520-b-4 + 20260522-night-3-b：順序 search → filter → limit；toggle 作用於 search/filter 後結果
      // Phase 20260522-night-3-b：search/filter 有作用時，顯示符合條件之全部結果，不被 SHOW_LIMIT 截斷
      function applyFilters() {
        var q = (search.value || '').toLowerCase().trim();
        var f = filter.value;
        var isFilterActive = (q.length > 0) || (f && f !== 'all');
        var matchedCount = 0;
        var shownCount = 0;
        rows.forEach(function (row, i) {
          var detail = details[i];
          var matches = true;
          if (q && (row.dataset.search || '').indexOf(q) === -1) matches = false;
          if (matches && !matchesFilter(row, f)) matches = false;
          var visible = false;
          if (matches) {
            matchedCount++;
            if (showAll || isFilterActive || shownCount < SHOW_LIMIT) {
              visible = true;
              shownCount++;
            }
          }
          row.hidden = !visible;
          if (!visible) {
            // 收合 detail 並移除 is-open
            detail.hidden = true;
            row.classList.remove('is-open');
          }
        });
        visibleCount.textContent = 'showing ' + shownCount + ' of ' + matchedCount + ' matched (' + rows.length + ' total)';
        // Phase 20260523-pm-10-admin-empty-filter-state-a: toggle fallback message when filter yields 0 matched rows
        // （per docs/admin-overview-audit-20260523.md §10.1 A7）；初始 posts.length === 0 為獨立 EJS-rendered empty state
        if (emptyFilterState) {
          emptyFilterState.hidden = !(isFilterActive && matchedCount === 0);
        }
        if (showAllToggle) {
          // Phase 20260522-night-3-b：search/filter active 時隱藏 toggle（已全顯）
          var needsToggle = !isFilterActive && matchedCount > SHOW_LIMIT;
          showAllToggle.hidden = !needsToggle;
          showAllToggle.textContent = showAll ? 'Show latest ' + SHOW_LIMIT : 'Show all';
        }
      }

      // Phase 20260522-night-3-d: client-side sort
      //   - reorder DOM 之 row + detail pairs（per pair appendChild）
      //   - reassign rows / details 陣列至新順序（讓 applyFilters 之 SHOW_LIMIT cap 對齊新 sort 順序）
      //   - 觸發 applyFilters() 重套 search / filter / limit
      //   - 不破壞 search / filter / detail panel
      function applySort() {
        if (!sort) return;
        var sortBy = sort.value || 'publishedAt-desc';
        var pairs = rows.map(function (row, i) {
          return [row, details[i]];
        });
        pairs.sort(function (a, b) {
          var ra = a[0], rb = b[0];
          if (sortBy === 'publishedAt-desc') {
            return (rb.dataset.publishedAt || '').localeCompare(ra.dataset.publishedAt || '');
          }
          if (sortBy === 'updatedAt-desc') {
            return (rb.dataset.updatedAt || '').localeCompare(ra.dataset.updatedAt || '');
          }
          // Phase 20260523-pm-16-admin-fbpostedat-sort-a: fbPostedAt desc 排序；per docs/admin-overview-audit-20260523.md §10.1 B4；dataset.fbPostedAt 來自 row data-fb-posted-at
          if (sortBy === 'fbPostedAt-desc') {
            return (rb.dataset.fbPostedAt || '').localeCompare(ra.dataset.fbPostedAt || '');
          }
          if (sortBy === 'title-asc') {
            return (ra.dataset.title || '').localeCompare(rb.dataset.title || '');
          }
          return 0;
        });
        var tbody = document.querySelector('#admin-table tbody');
        if (tbody) {
          pairs.forEach(function (pair) {
            tbody.appendChild(pair[0]);
            if (pair[1]) tbody.appendChild(pair[1]);
          });
        }
        rows = pairs.map(function (p) { return p[0]; });
        details = pairs.map(function (p) { return p[1]; });
        applyFilters();
      }

      search.addEventListener('input', applyFilters);
      filter.addEventListener('change', applyFilters);
      if (showAllToggle) {
        showAllToggle.addEventListener('click', function () {
          showAll = !showAll;
          applyFilters();
        });
      }
      // Phase 20260522-night-3-d: sort dropdown listener
      if (sort) {
        sort.addEventListener('change', applySort);
      }

      // 點 row 展開 / 收合 detail
      // Phase 20260522-night-3-d: 捕捉 detail by reference（rowDetail closure）；避免 sort 重排後 closured index 失效
      rows.forEach(function (row, i) {
        var rowDetail = details[i];
        row.addEventListener('click', function () {
          var nowOpen = rowDetail.hidden;
          rowDetail.hidden = !nowOpen;
          row.classList.toggle('is-open', nowOpen);
        });
      });

      // Initial apply (no filter)
      applyFilters();

      // Phase Admin-2-b-1: dry-run edit viewer handlers
      // 純 client-side：不寫任何檔案；不呼叫 fetch / XHR / fs；無 Apply / Save / Write button。
      // 點 dry-run section 內 button / input 時 stopPropagation 避免冒泡至 row click（toggle detail）。
      function escapeHtml(s) {
        var div = document.createElement('div');
        div.textContent = s == null ? '' : String(s);
        return div.innerHTML;
      }
      var drySections = document.querySelectorAll('.dry-run-section');
      drySections.forEach(function (section) {
        section.addEventListener('click', function (e) { e.stopPropagation(); });
        var toggle = section.querySelector('.dry-run-toggle');
        var form = section.querySelector('.dry-run-form');
        var compute = section.querySelector('.dry-run-compute');
        var result = section.querySelector('.dry-run-result');
        var diffRows = section.querySelector('.dry-run-diff-rows');
        var changedCount = section.querySelector('.changed-count');
        if (!toggle || !form || !compute || !result || !diffRows || !changedCount) return;
        toggle.addEventListener('click', function () {
          form.hidden = !form.hidden;
          toggle.textContent = form.hidden ? 'Start Edit' : 'Cancel';
          if (form.hidden) result.hidden = true;
        });
        compute.addEventListener('click', function () {
          var fields = ['description', 'searchDescription', 'titleEn', 'coverAlt'];
          var changed = 0;
          var html = '';
          fields.forEach(function (name) {
            var oldCell = section.querySelector('[data-field="' + name + '"]');
            var input = section.querySelector('[data-input="' + name + '"]');
            var oldVal = oldCell ? (oldCell.dataset.current || '') : '';
            var newVal = input ? (input.value || '') : '';
            var statusClass, statusText;
            if (oldVal === newVal) {
              if (oldVal === '') { statusClass = 'status-empty'; statusText = 'unchanged / empty'; }
              else { statusClass = 'status-unchanged'; statusText = 'unchanged'; }
            } else {
              statusClass = 'status-changed';
              statusText = 'changed';
              changed++;
            }
            html += '<tr>'
              + '<td class="mono">' + escapeHtml(name) + '</td>'
              + '<td class="dry-run-old-value">' + (oldVal === '' ? '<span class="status-empty">(empty)</span>' : escapeHtml(oldVal)) + '</td>'
              + '<td class="dry-run-new-value">' + (newVal === '' ? '<span class="status-empty">(empty)</span>' : escapeHtml(newVal)) + '</td>'
              + '<td class="' + statusClass + '">' + statusText + '</td>'
              + '</tr>';
          });
          diffRows.innerHTML = html;
          changedCount.textContent = changed;
          result.hidden = false;
        });
      });

      // Phase 20260520-fb-p5-b: FB sidecar dry-run editor handlers
      // 純 client-side：無 fs.write / 無 fetch / 無 XHR / 無 form submit / 無 Apply button。
      // 點 fb-dry-run-section 內 button / input 時 stopPropagation 避免冒泡至 row click（toggle detail）。
      // 與既有 SEO dry-run viewer 使用獨立 .fb-dry-run-* class 不衝突。
      var fbDrySections = document.querySelectorAll('.fb-dry-run-section');
      fbDrySections.forEach(function (section) {
        section.addEventListener('click', function (e) { e.stopPropagation(); });
        var fbToggle = section.querySelector('.fb-dry-run-toggle');
        var fbCancel = section.querySelector('.fb-dry-run-cancel');
        var fbForm = section.querySelector('.fb-dry-run-form');
        var fbCompute = section.querySelector('.fb-dry-run-compute');
        var fbResult = section.querySelector('.fb-dry-run-result');
        var fbDiffRows = section.querySelector('.fb-dry-run-diff-rows');
        var fbChangedCount = section.querySelector('.fb-dry-run-changed-count');
        var fbAfterBlock = section.querySelector('.fb-dry-run-after');
        if (!fbToggle || !fbForm || !fbCompute || !fbResult || !fbDiffRows || !fbChangedCount) return;

        function setFbFormOpen(open) {
          fbForm.hidden = !open;
          fbToggle.hidden = open;
          if (fbCancel) fbCancel.hidden = !open;
          if (!open) fbResult.hidden = true;
        }
        fbToggle.addEventListener('click', function () { setFbFormOpen(true); });
        if (fbCancel) fbCancel.addEventListener('click', function () { setFbFormOpen(false); });

        fbCompute.addEventListener('click', function () {
          var fbFields = [
            { name: 'enabled', type: 'bool' },
            { name: 'status', type: 'string' },
            { name: 'postUrl', type: 'string' },
            { name: 'postedAt', type: 'string' },
            { name: 'postId', type: 'string' },
            { name: 'campaign', type: 'string' },
            { name: 'audience', type: 'string' },
            { name: 'title', type: 'string' },
            { name: 'titleEn', type: 'string' },
            { name: 'hashtags', type: 'array' },
            { name: 'imageUrl', type: 'string' },
            { name: 'note', type: 'string' },
          ];
          var changedFb = 0;
          var htmlFb = '';
          var afterLines = [];
          fbFields.forEach(function (f) {
            var oldCell = section.querySelector('[data-fb-field="' + f.name + '"]');
            var input = section.querySelector('[data-fb-input="' + f.name + '"]');
            var oldVal = oldCell ? (oldCell.dataset.current || '') : '';
            var newVal = input ? (input.value || '') : '';
            var oldDisp = oldVal;
            var newDisp = newVal;
            var isEqual;
            if (f.type === 'array') {
              var splitNorm = function (s) {
                return s.split(/\r?\n/).map(function(x){return x.trim();}).filter(function(x){return x !== '';});
              };
              var oldArr = oldVal === '' ? [] : splitNorm(oldVal);
              var newArr = splitNorm(newVal);
              oldDisp = oldArr.join('\n');
              newDisp = newArr.join('\n');
              isEqual = JSON.stringify(oldArr) === JSON.stringify(newArr);
              afterLines.push(f.name + ':');
              if (newArr.length === 0) { afterLines.push('  []'); }
              else { newArr.forEach(function(h){ afterLines.push('  - "' + h.replace(/"/g, '\\"') + '"'); }); }
            } else if (f.type === 'bool') {
              isEqual = oldVal === newVal;
              afterLines.push(f.name + ': ' + (newVal === 'true' ? 'true' : 'false'));
            } else {
              isEqual = oldVal === newVal;
              afterLines.push(f.name + ': "' + newVal.replace(/"/g, '\\"') + '"');
            }
            var statusStyle, statusText;
            if (isEqual) {
              if (oldDisp === '' && newDisp === '') { statusStyle = 'color: #999; font-style: italic;'; statusText = 'unchanged / empty'; }
              else { statusStyle = 'color: #155724;'; statusText = 'unchanged'; }
            } else {
              statusStyle = 'color: #d63384; font-weight: 600;';
              statusText = 'changed';
              changedFb++;
            }
            var emptyMark = '<span style="color:#999;font-style:italic;">(empty)</span>';
            htmlFb += '<tr>'
              + '<td class="mono">' + escapeHtml(f.name) + '</td>'
              + '<td style="max-width: 14rem; word-break: break-word; white-space: pre-wrap;">' + (oldDisp === '' ? emptyMark : escapeHtml(oldDisp)) + '</td>'
              + '<td style="max-width: 14rem; word-break: break-word; white-space: pre-wrap;">' + (newDisp === '' ? emptyMark : escapeHtml(newDisp)) + '</td>'
              + '<td style="' + statusStyle + '">' + statusText + '</td>'
              + '</tr>';
          });
          fbDiffRows.innerHTML = htmlFb;
          fbChangedCount.textContent = changedFb;
          if (fbAfterBlock) fbAfterBlock.textContent = afterLines.join('\n');
          fbResult.hidden = false;
        });
      });
    })();
  </script>
  <% } %>

  <%# Phase 20260608-night-1 commerce-admin-copyable-yaml-snippet-source-only-a
      per docs/20260608-commerce-admin-copyable-yaml-snippet-preanalysis.md §5 / §6 / §7 / §10 / §14
      - 純 client-side：無 fetch / XHR / form submit / fs write / safeWrite caller / middleware ping
      - 與 posts.length 無關（snippet 來源為 registry；故不放在 posts.length > 0 之 script 內）
      - role 空 → 省略 key（per preanalysis §6.1 Design A；避免 C8 invalid-role 誤觸）
      - labelOverride 空 → 省略 key；非空時以 double-quoted + escape 包裝（display-safe single-line）
      - clipboard：navigator.clipboard.writeText 優先；不可用時 fallback execCommand('copy')；皆失敗則僅顯示提示
  %>
  <% if (commerceRows.length > 0) { %>
  <script>
    (function () {
      var pickEls = document.querySelectorAll('[data-commerce-pick]');
      var output = document.getElementById('commerce-snippet-output');
      var copyBtn = document.getElementById('commerce-snippet-copy');
      var statusEl = document.getElementById('commerce-snippet-copy-status');
      if (!pickEls.length || !output || !copyBtn) return;

      function yamlQuote(s) {
        var t = String(s == null ? '' : s)
          .replace(/\r?\n/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();
        return t.replace(/\\/g, '\\\\').replace(/"/g, '\\"');
      }

      function buildSnippet() {
        var items = [];
        for (var i = 0; i < pickEls.length; i++) {
          var cb = pickEls[i];
          if (!cb.checked) continue;
          var idx = cb.getAttribute('data-commerce-pick');
          var linkId = cb.getAttribute('data-commerce-link-id') || '';
          if (!linkId) continue;
          var roleEl = document.querySelector('[data-commerce-role="' + idx + '"]');
          var labelEl = document.querySelector('[data-commerce-label="' + idx + '"]');
          var role = roleEl ? (roleEl.value || '') : '';
          var label = labelEl ? (labelEl.value || '') : '';
          var lines = ['    - ref: ' + linkId];
          if (role !== '') lines.push('      role: ' + role);
          var labelTrim = label.replace(/\s+/g, ' ').trim();
          if (labelTrim !== '') lines.push('      labelOverride: "' + yamlQuote(label) + '"');
          items.push(lines.join('\n'));
        }
        if (items.length === 0) {
          output.value = '# 勾選上方 entry 以產生 snippet';
          copyBtn.disabled = true;
          copyBtn.setAttribute('aria-disabled', 'true');
          return;
        }
        output.value = 'affiliate:\n  links:\n' + items.join('\n') + '\n';
        copyBtn.disabled = false;
        copyBtn.setAttribute('aria-disabled', 'false');
      }

      function showStatus(msg, isErr) {
        if (!statusEl) return;
        statusEl.textContent = msg;
        statusEl.style.color = isErr ? '#a00' : '#080';
        setTimeout(function () {
          if (statusEl.textContent === msg) statusEl.textContent = '';
        }, 2000);
      }

      function fallbackCopy() {
        try {
          output.removeAttribute('readonly');
          output.focus();
          output.select();
          var ok = false;
          try { ok = document.execCommand('copy'); } catch (e) { ok = false; }
          output.setAttribute('readonly', 'readonly');
          if (ok) { showStatus('已複製 (Copied)', false); }
          else { showStatus('複製失敗，請手動選取後 Ctrl+C', true); }
        } catch (e) {
          showStatus('複製失敗，請手動選取後 Ctrl+C', true);
        }
      }

      copyBtn.addEventListener('click', function () {
        if (copyBtn.disabled) return;
        var text = output.value || '';
        if (!text || text.charAt(0) === '#') {
          showStatus('尚未選取 entry', true);
          return;
        }
        if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
          navigator.clipboard.writeText(text).then(function () {
            showStatus('已複製 (Copied)', false);
          }).catch(function () {
            fallbackCopy();
          });
        } else {
          fallbackCopy();
        }
      });

      function wireInput(el, evt) { el.addEventListener(evt, buildSnippet); }
      for (var i = 0; i < pickEls.length; i++) wireInput(pickEls[i], 'change');
      document.querySelectorAll('[data-commerce-role]').forEach(function (el) { wireInput(el, 'change'); });
      document.querySelectorAll('[data-commerce-label]').forEach(function (el) { wireInput(el, 'input'); });

      buildSnippet();
    })();
  </script>
  <% } %>

  <%# Phase 20260617-night-admin-categories-tags-collapsible-split-implementation-a:
      最小、隔離之 client script —— 當 location.hash 指向某 <details> 內部元素（如 nav #tags 在使用者手動收合 Tags 群後），
      自動展開其祖先 <details>，確保錨點跳轉不會落入收合區而「找不到」。
      只讀 location.hash + 設定 details.open；不碰 filter / search / sort / detail-panel toggle 任何邏輯。 -%>
  <script>
    (function () {
      function openHashDetails() {
        var h = location.hash;
        if (!h || h.length < 2) return;
        var el;
        try { el = document.getElementById(decodeURIComponent(h.slice(1))); } catch (e) { return; }
        if (!el) return;
        var d = el.closest ? el.closest('details') : null;
        while (d) {
          d.open = true;
          d = (d.parentElement && d.parentElement.closest) ? d.parentElement.closest('details') : null;
        }
      }
      window.addEventListener('hashchange', openHashDetails);
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', openHashDetails);
      } else {
        openHashDetails();
      }
    })();
  </script>
</body>
</html>
