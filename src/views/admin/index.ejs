                    <% items.forEach(function(item) { %>
                      <%
                        var skKnown = false;
                        srcOpts.forEach(function(o) { if (o.sourceKey === item.sourceKey) { skKnown = true; } });
                        var skClass = !item.sourceKey ? 'b-info' : (skKnown ? 'b-ok' : 'b-missing');
                        var skDisplay = !item.sourceKey ? '(none)' : item.sourceKey;
                      %>
                      <tr>
                        <td class="mono"><%= item.index %></td>
                        <td><% if (item.kind) { %><span class="badge b-info"><%= item.kind %></span><% } else { %><span class="badge b-missing">(none)</span><% } %></td>
                        <td><% if (item.platform) { %><span class="badge b-tag"><%= item.platform %></span><% } else { %><span class="text-muted">—</span><% } %></td>
                        <td><span class="badge <%= skClass %>"><%= skDisplay %></span><% if (item.sourceKey && !skKnown) { %><br><span class="text-muted" style="font-size: 0.78em;">⚠ 未知 / inactive</span><% } %></td>
                        <td>
                          <% if (item.title) { %><div><%= item.title %></div><% } %>
                          <% if (item.url) { %><div class="mono" style="font-size: 0.85em; word-break: break-all;"><%= item.url %></div><% } %>
                          <% if (!item.title && !item.url) { %><span class="empty">(empty)</span><% } %>
                        </td>
                        <td>
                          <select disabled aria-disabled="true" title="Read-only preview — no write enabled. 真正寫入須未來 Admin write phase 啟用。" style="width: 100%; padding: 0.2rem; font-family: inherit; font-size: 0.85em; background: #f5f5f5; color: #555; cursor: not-allowed;">
                            <option value="" <%= !item.sourceKey ? 'selected' : '' %>>— 未指定 —</option>
                            <% srcOpts.forEach(function(o) { %>
                              <option value="<%= o.sourceKey %>" <%= (o.sourceKey === item.sourceKey) ? 'selected' : '' %>>[<%= o.sourceType %>] <%= o.displayLabel %> (<%= o.sourceKey %>)</option>
                            <% }); %>
                            <% if (item.sourceKey && !skKnown) { %>
                              <option value="<%= item.sourceKey %>" selected>⚠ 未知 / inactive: <%= item.sourceKey %></option>
                            <% } %>
                          </select>
                        </td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              <% } %>
            <% }); %>
            <p class="text-muted" style="font-size: 0.78em; margin: 0.5rem 0 0;">
              注：本 phase 不啟用 source-inactive validation rule（per preanalysis §6 / §11.3）；inactive source 引用當前仍由既有 <code>source-key-not-found</code> rule 捕捉。selector 純顯示概念；frontmatter 寫入屬獨立未來 phase（per <code>docs/admin-2-write-pre-analysis.md</code> §15.F）。
            </p>
          </div>
          <% } %>

