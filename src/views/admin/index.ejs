                  <% if (sb.archived > 0)  { %><span class="ss-archived"  title="archived <%= sb.archived %>"   style="flex: <%= sb.archived %> 0 0"></span><% } %>
                  <% if (sb.other > 0)     { %><span class="ss-other"     title="other <%= sb.other %>"         style="flex: <%= sb.other %> 0 0"></span><% } %>
                </span>
