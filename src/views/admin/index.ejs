          <% var srcOpts = Array.isArray(p.sourceOptions) ? p.sourceOptions : []; %>
          <% var rItems = Array.isArray(p.relatedLinksItems) ? p.relatedLinksItems : []; %>
          <% var oItems = Array.isArray(p.otherLinksItems) ? p.otherLinksItems : []; %>
          <% if (rItems.length > 0 || oItems.length > 0) { %>
