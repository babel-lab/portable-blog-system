        //   Even when disable=true (export not gated), this still updates so
        //   the user can see the consolidated blocking / warning list.
        renderReadyPreflight(analyzeReadyGap(input));
        // Phase 20260627-admin-category-tag-registry-hints-implementation-a:
        //   Registry alignment hints (read-only; never gates export).
        // Phase 20260701-admin-tag-registry-inline-hint-slice-c1:
        //   Lifted into a local var so the tags-only inline hint reuses the same
        //   computed result (no double compute; no new registry source).
        var regHintsResult = analyzeRegistryHints(input, REGISTRY_SNAPSHOT);
        renderRegistryHints(regHintsResult);
        renderTagsRegistryHint(regHintsResult, input);
        // Phase 20260627-admin-draft-markdown-output-usability-slice-a:
        //   At-a-glance summary strip + per-field char counters. Mirrors
        //   admin-markdown-export.js buildExportSummary (smoke 76-86).
        renderExportSummary(buildExportSummary(input));
        // Phase 20260701-admin-slug-suggestion-helper-slice-a:
        //   Display-only slug suggestion strip (below #npd-slug helper span).
        //   Copy-only; never auto-fills SLUG_EL.value; never influences the
        //   markdown export path.
        renderSlugSuggestion(input);
      }

      function fallbackCopy() {
        try {
          OUT_EL.removeAttribute('readonly');
          OUT_EL.focus();
          OUT_EL.select();
          var ok = false;
          try { ok = document.execCommand('copy'); } catch (e) { ok = false; }
          OUT_EL.setAttribute('readonly', 'readonly');
          if (ok) { showStatus('已複製 (Copied)', false); }
          else { showStatus('複製失敗，請手動選取後 Ctrl+C', true); }
        } catch (e) {
          showStatus('複製失敗，請手動選取後 Ctrl+C', true);
        }
      }
      COPY_BTN.addEventListener('click', function () {
        if (COPY_BTN.disabled) return;
        var text = OUT_EL.value || '';
        if (!text) { showStatus('尚無內容', true); return; }
        if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
          navigator.clipboard.writeText(text).then(function () {
            showStatus('已複製 (Copied)', false);
          }).catch(function () { fallbackCopy(); });
        } else { fallbackCopy(); }
      });

      // Phase 20260627-admin-markdown-import-checklist-slice2-a:
      //   Manual import flow button handlers — copy strings to clipboard only.
      //   No fs / fetch / write path; status surfaced in #npd-flow-status (2s clear).
      function showFlowStatus(msg, isErr) {
        if (!FLOW_STATUS_EL) return;
        FLOW_STATUS_EL.textContent = msg;
        FLOW_STATUS_EL.style.color = isErr ? '#a00' : '#080';
        setTimeout(function () {
          if (FLOW_STATUS_EL.textContent === msg) FLOW_STATUS_EL.textContent = '';
        }, 2000);
      }
      // Phase 20260701-admin-ready-gap-copy-local-status-slice2b:
      //   Local status for the Copy ready-gap report button. #npd-flow-status
      //   sits next to the manual-import-flow buttons (Copy target path / Copy
      //   validation command), far from the Ready preflight panel — so a
      //   ready-gap copy's "已複製" landed out of the user's eyeline and read
      //   as a dead button. This mirrors showFlowStatus's 2s-clear contract
      //   onto #npd-gap-status beside the button. DOM-text only; no fs / fetch.
      function showGapStatus(msg, isErr) {
        if (!GAP_STATUS_EL) return;
        GAP_STATUS_EL.textContent = msg;
        GAP_STATUS_EL.style.color = isErr ? '#a00' : '#080';
        setTimeout(function () {
          if (GAP_STATUS_EL.textContent === msg) GAP_STATUS_EL.textContent = '';
        }, 2000);
      }
      // Phase 20260701-admin-ready-gap-copy-local-status-slice2b:
      //   statusFn selects which status sink receives success / failure
      //   feedback. Omitted (Copy target path / Copy validation command) →
      //   defaults to showFlowStatus (#npd-flow-status) so existing buttons are
      //   byte-for-runtime unchanged. Copy ready-gap report passes showGapStatus
      //   so its feedback lands beside the button instead of far away.
      function copyTextToClipboard(text, okMsg, statusFn) {
        var notify = typeof statusFn === 'function' ? statusFn : showFlowStatus;
        if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
          navigator.clipboard.writeText(text).then(function () {
            notify(okMsg, false);
          }).catch(function () {
            notify('複製失敗，請手動選取', true);
          });
        } else {
          // execCommand fallback via temporary textarea (no fs / fetch).
          try {
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.setAttribute('readonly', 'readonly');
            ta.style.position = 'absolute';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            var ok = false;
            try { ok = document.execCommand('copy'); } catch (e) { ok = false; }
            document.body.removeChild(ta);
            if (ok) notify(okMsg, false);
            else notify('複製失敗，請手動選取', true);
          } catch (e) {
            notify('複製失敗，請手動選取', true);
          }
        }
      }
      if (COPY_PATH_BTN) {
        COPY_PATH_BTN.addEventListener('click', function () {
          if (COPY_PATH_BTN.disabled) return;
          var tp = buildTargetPath(SITE_EL.value, DATE_EL.value, SLUG_EL.value);
          if (tp === '') { showFlowStatus('target path 尚未合法', true); return; }
          copyTextToClipboard(tp, '已複製 path');
        });
      }
      if (COPY_CMD_BTN) {
        COPY_CMD_BTN.addEventListener('click', function () {
          copyTextToClipboard(VALIDATION_COMMAND, '已複製指令');
        });
      }
      // Phase 20260701-admin-ready-gap-report-copy-slice-a:
      //   Copy ready-gap report — clipboard-only. Builds the plain-text digest
      //   from the current form state and copies it via the vetted
      //   copyTextToClipboard() helper. No repo write, no upload, no fetch.
      if (COPY_GAP_BTN) {
        COPY_GAP_BTN.addEventListener('click', function () {
          copyTextToClipboard(buildReadyGapReport(readInput()), '已複製 ready-gap report', showGapStatus);
        });
      }

      DL_BTN.addEventListener('click', function () {
        if (DL_BTN.disabled) return;
        var fn = buildFilename(DATE_EL.value, SLUG_EL.value);
        if (fn === '') { showStatus('filename 不合法', true); return; }
        var text = OUT_EL.value || '';
        if (!text) { showStatus('尚無內容', true); return; }
        try {
          var blob = new Blob([text], { type: 'text/markdown;charset=utf-8' });
          var url = URL.createObjectURL(blob);
          var a = document.createElement('a');
          a.href = url;
          a.download = fn;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          setTimeout(function () { URL.revokeObjectURL(url); }, 1000);
          showStatus('已下載 ' + fn, false);
        } catch (e) {
          showStatus('下載失敗：' + (e && e.message ? e.message : 'unknown'), true);
        }
      });

      var debounceTimer = null;
      function debounceRecompute() {
        if (debounceTimer) clearTimeout(debounceTimer);
        debounceTimer = setTimeout(recompute, 50);
      }
      [SITE_EL, KIND_EL, PRIM_EL, CAT_EL].forEach(function (el) { el.addEventListener('change', recompute); });
      // Phase 20260627-admin-richer-fields-slice-a:
      //   Wire input events for the optional SEO / Cover fields so the Ready
      //   preflight panel + markdown preview recompute as Dean fills them.
      [TITLE_EL, TITLE_EN_EL, SLUG_EL, DATE_EL, TAGS_EL, DESC_EL, SEARCH_DESC_EL, COVER_EL, COVER_ALT_EL, BODY_EL]
        .filter(function (el) { return el; })
        .forEach(function (el) { el.addEventListener('input', debounceRecompute); });

      // Phase 20260629-admin-today-date-shortcut-slice-a:
      //   "今天" convenience button: fills #npd-date with today's local
      //   YYYY-MM-DD via todayIso() (local parts; no toISOString — avoids
      //   UTC date-skip near midnight) and dispatches an 'input' event so
      //   the existing debounceRecompute path picks it up like any other
      //   keystroke. Net-additive: the load-time auto-prefill at L~3549
      //   stays intact, so initial ready/export gating is unchanged.
      var TODAY_BTN = document.getElementById('npd-today');
      if (TODAY_BTN && DATE_EL) {
        TODAY_BTN.addEventListener('click', function () {
          DATE_EL.value = todayIso();
          DATE_EL.dispatchEvent(new Event('input', { bubbles: true }));
